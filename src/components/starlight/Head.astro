---
const { head } = Astro.locals.starlightRoute;

const cleanedHead = head.map((item: any) => {
	if (item.tag === 'link' && item.attrs?.rel === 'canonical') {
		return {
			...item,
			attrs: {
				...item.attrs,
				href: item.attrs.href.replace(/\.html$/, '')
			}
		};
	}

	if (item.tag === 'meta' && item.attrs?.property === 'og:url') {
		return {
			...item,
			attrs: {
				...item.attrs,
				content: item.attrs.content.replace(/\.html$/, '')
			}
		};
	}

	if (item.tag === 'link' && item.attrs?.rel === 'alternate' && item.attrs?.hreflang) {
		return {
			...item,
			attrs: {
				...item.attrs,
				href: item.attrs.href.replace(/\.html$/, '')
			}
		};
	}

	return item;
});
---

{cleanedHead.map(({ tag: Tag, attrs, content }: any) => <Tag {...attrs} set:html={content} />)}
