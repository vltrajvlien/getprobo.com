---
import { getTranslator, getLink } from "../../lib/i18n.ts";
import LogosScroll from "../LogosScroll.svelte";

const __ = await getTranslator(Astro.currentLocale);

const clientLogos = [
  { src: "/clients/trace_for_good.webp", alt: "Trace for Good", width: 107 },
  { src: "/clients/jimo.svg", alt: "Jimo", width: 32 },
  { src: "/clients/lucis.svg", alt: "Lucis", width: 53 },
  { src: "/clients/filz.svg", alt: "Filz", width: 57 },
  { src: "/clients/ahrefs.svg", alt: "Ahrefs", width: 62 },
];

const openSourceFeatures = [
  __("Self-hosted compliance platform"),
  __("Framework tracking (SOC 2, ISO 27001, GDPR...)"),
  __("Automated evidence collection"),
  __("Community support"),
];

const fullServiceFeatures = [
  __("Dedicated compliance officer"),
  __("Gap assessment & custom policies"),
  __("Vendor reviews & employee training"),
  __("Audit prep & representation"),
  __("12 months maintenance included"),
];

const enterpriseFeatures = [
  __("Priority onboarding"),
  __("Custom SLAs"),
  __("Dedicated account manager"),
];
---

<section class="bg-level-0 flex flex-col items-center">
  <!-- Hero -->
  <div class="flex gap-10 items-end overflow-clip max-w-[1080px] w-full">
    <!-- Left decorative vertical line -->
    <div class="self-stretch flex items-end hidden sm:flex">
      <div class="w-px h-full max-h-32 bg-linear-to-t from-[#ecefe8] to-transparent"></div>
    </div>

    <!-- Hero content -->
    <div class="flex flex-1 flex-col sm:flex-row gap-6 items-start sm:items-end min-w-0 pb-10 pt-16 px-6 sm:px-0">
      <div class="flex flex-col gap-6 shrink-0">
        <h1 class="text-[48px] font-medium leading-none tracking-[-1.44px] text-foreground">
          {__("Get audit-ready.")}
        </h1>
        <div class="text-lg leading-[1.5] text-muted-foreground sm:w-[530px]">
          <p>{__("We handle everything from gap assessment to audit day.")}</p>
          <p>{__("Pick the plan that fits, or deploy our open-source platform.")}</p>
        </div>
      </div>

      <div class="flex flex-1 flex-col gap-4 items-center min-w-0 hidden sm:flex">
        <p class="text-xs leading-[1.3] text-muted-foreground whitespace-nowrap">
          {__("They got certified with us")}
        </p>
        <div class="w-full relative overflow-hidden">
          <LogosScroll class="flex h-4 items-center" client:load>
            {clientLogos.map((logo) => (
              <span class="px-2.5 flex items-center">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-4 shrink-0 opacity-60"
                  style={`width: ${logo.width}px`}
                  loading="lazy"
                />
              </span>
            ))}
          </LogosScroll>
          <div class="absolute left-0 top-0 bottom-0 w-12 bg-linear-to-r from-level-0 to-transparent pointer-events-none"></div>
          <div class="absolute right-0 top-0 bottom-0 w-12 bg-linear-to-l from-level-0 to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>

    <!-- Right decorative vertical line -->
    <div class="self-stretch flex items-end hidden sm:flex">
      <div class="w-px h-full max-h-32 bg-linear-to-t from-[#ecefe8] to-transparent"></div>
    </div>
  </div>

  <!-- Cards row with decorative side lines -->
  <div class="flex items-stretch w-full">
    <!-- Left decorative horizontal lines -->
    <div class="flex-1 flex-col justify-between overflow-clip hidden sm:flex">
      <div class="h-px w-32 bg-linear-to-l from-[#ecefe8] to-transparent self-end"></div>
      <div class="h-px w-32 bg-linear-to-l from-[#ecefe8] to-transparent self-end"></div>
    </div>

    <!-- Three pricing cards -->
    <div class="flex flex-col sm:flex-row items-stretch max-w-[1080px] w-full">
      <!-- Open Source Card -->
      <div class="flex-1 border-l border-t border-b border-r sm:border-r-0 border-border-low p-6 sm:p-10 flex flex-col gap-16">
        <div class="flex flex-col gap-6">
          <!-- DownloadSimple Light (Phosphor) -->
          <svg class="size-8 text-muted-foreground" viewBox="0 0 256 256" fill="currentColor">
            <path d="M222,144v64a6,6,0,0,1-6,6H40a6,6,0,0,1-6-6V144a6,6,0,0,1,12,0v58H210V144a6,6,0,0,1,12,0Zm-98.24,4.24a6,6,0,0,0,8.48,0l40-40a6,6,0,0,0-8.48-8.48L134,129.51V32a6,6,0,0,0-12,0v97.51L92.24,99.76a6,6,0,0,0-8.48,8.48Z"/>
          </svg>
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Open Source")}
          </p>
          <p class="text-[40px] font-medium text-muted-foreground tracking-[-1px] leading-none">
            {__("Free")}
          </p>
        </div>

        <div class="flex flex-col gap-6 flex-1">
          <div class="flex flex-col gap-6">
            <p class="text-sm text-muted-foreground leading-[1.5]">
              {__("Run compliance on your own terms.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3 flex-1">
            {openSourceFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <svg class="size-4 shrink-0 text-quaternary mt-px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-muted-foreground leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/docs/self-hosting/docker-compose")}
          class="flex items-center justify-center h-8 w-full rounded-full border border-border-mid text-base font-medium tracking-[-0.45px] text-foreground hover:bg-highlight transition-colors"
        >
          {__("Deploy for free")}
        </a>
      </div>

      <!-- Full Service Card -->
      <div class="flex-1 border border-border-low p-6 sm:p-10 flex flex-col gap-16 relative overflow-clip">
        <!-- Green glow background -->
        <div
          class="absolute size-[518px] rounded-full bg-[#e4f7c7]/40 blur-[100px] pointer-events-none"
          style="left: calc(50% + 29px); top: calc(50% + 103px); transform: translate(-50%, -50%);"
        ></div>

        <div class="flex flex-col gap-6 relative">
          <div class="flex items-start justify-between">
            <!-- UsersThree Light (Phosphor) -->
            <svg class="size-8 text-muted-foreground" viewBox="0 0 256 256" fill="currentColor">
              <path d="M243.6,148.8a6,6,0,0,1-8.4-1.2A53.58,53.58,0,0,0,192,126a6,6,0,0,1,0-12,26,26,0,1,0-25.18-32.5,6,6,0,0,1-11.62-3,38,38,0,1,1,59.91,39.63A65.69,65.69,0,0,1,244.8,140.4,6,6,0,0,1,243.6,148.8ZM189.19,213a6,6,0,0,1-2.19,8.2,5.9,5.9,0,0,1-3,.81,6,6,0,0,1-5.2-3,59,59,0,0,0-101.62,0,6,6,0,1,1-10.38-6A70.1,70.1,0,0,1,103,182.55a46,46,0,1,1,50.1,0A70.1,70.1,0,0,1,189.19,213ZM128,178a34,34,0,1,0-34-34A34,34,0,0,0,128,178ZM70,120a6,6,0,0,0-6-6A26,26,0,1,1,89.18,81.49a6,6,0,1,0,11.62-3,38,38,0,1,0-59.91,39.63A65.69,65.69,0,0,0,11.2,140.4a6,6,0,1,0,9.6,7.2A53.58,53.58,0,0,1,64,126,6,6,0,0,0,70,120Z"/>
            </svg>
            <span class="bg-active text-success text-xs px-2 py-0.5 rounded-full">
              {__("Recommended")}
            </span>
          </div>
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Full Service")}
          </p>
          <div class="flex gap-[9px] items-center">
            <p class="text-[40px] font-medium text-foreground tracking-[-1px] leading-none">
              $8,000
            </p>
            <div class="text-xs leading-[1.3] text-muted-foreground">
              <p>{__("Starting at")}</p>
              <p>{__("Billed annually")}</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-6 relative">
          <div class="flex flex-col gap-6">
            <p class="text-sm text-muted-foreground leading-[1.5]">
              {__("Our experts get you certified.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3">
            {fullServiceFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <svg class="size-4 shrink-0 text-accent mt-px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-foreground tracking-[-0.14px] leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="relative flex items-center justify-center h-8 w-full rounded-full bg-foreground text-base font-semibold tracking-[-0.45px] text-primary-foreground hover:bg-foreground/90 transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>

      <!-- Enterprise Card -->
      <div class="flex-1 border-r border-t border-b border-l sm:border-l-0 border-border-low p-6 sm:p-10 flex flex-col gap-16">
        <div class="flex flex-col gap-6">
          <!-- Building Light (Phosphor) -->
          <svg class="size-8 text-muted-foreground" viewBox="0 0 256 256" fill="currentColor">
            <path d="M232,226H206V30h10a6,6,0,0,0,0-12H40a6,6,0,0,0,0,12H50V226H24a6,6,0,0,0,0,12H232a6,6,0,0,0,0-12ZM62,30H194V226H158V184a6,6,0,0,0-6-6H104a6,6,0,0,0-6,6v42H62Zm84,196H110V190h36ZM90,64a6,6,0,0,1,6-6h16a6,6,0,0,1,0,12H96A6,6,0,0,1,90,64Zm48,0a6,6,0,0,1,6-6h16a6,6,0,0,1,0,12H144A6,6,0,0,1,138,64ZM90,104a6,6,0,0,1,6-6h16a6,6,0,0,1,0,12H96A6,6,0,0,1,90,104Zm48,0a6,6,0,0,1,6-6h16a6,6,0,0,1,0,12H144A6,6,0,0,1,138,104ZM96,150a6,6,0,0,1,0-12h16a6,6,0,0,1,0,12Zm42-6a6,6,0,0,1,6-6h16a6,6,0,0,1,0,12H144A6,6,0,0,1,138,144Z"/>
          </svg>
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Enterprise")}
          </p>
          <p class="text-[40px] font-medium text-foreground tracking-[-1px] leading-none">
            {__("Custom")}
          </p>
        </div>

        <div class="flex flex-col gap-6 flex-1">
          <div class="flex flex-col gap-6">
            <p class="text-sm text-muted-foreground leading-[1.5]">
              {__("Built around your organization.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3 flex-1">
            {enterpriseFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <svg class="size-4 shrink-0 text-accent mt-px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="text-sm text-foreground tracking-[-0.14px] leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="flex items-center justify-center h-8 w-full rounded-full border border-border-mid text-base font-medium tracking-[-0.45px] text-foreground hover:bg-highlight transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>
    </div>

    <!-- Right decorative horizontal lines -->
    <div class="flex-1 flex-col justify-between overflow-clip hidden sm:flex">
      <div class="h-px w-32 bg-linear-to-r from-[#ecefe8] to-transparent"></div>
      <div class="h-px w-32 bg-linear-to-r from-[#ecefe8] to-transparent"></div>
    </div>
  </div>

  <!-- Bottom decorative vertical lines -->
  <div class="justify-between max-w-[1080px] w-full h-32 overflow-clip hidden sm:flex">
    <div class="w-px h-full bg-linear-to-b from-[#ecefe8] to-transparent"></div>
    <div class="w-px h-full bg-linear-to-b from-[#ecefe8] to-transparent"></div>
  </div>
</section>
