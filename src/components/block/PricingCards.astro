---
import { getTranslator, getLink } from "../../lib/i18n.ts";
import LogosScroll from "../LogosScroll.svelte";

import DownloadSimpleSvg from "@phosphor-icons/core/assets/light/download-simple-light.svg?raw";
import UsersThreeSvg from "@phosphor-icons/core/assets/light/users-three-light.svg?raw";
import BuildingSvg from "@phosphor-icons/core/assets/light/building-light.svg?raw";
import CheckSvg from "@phosphor-icons/core/assets/light/check-light.svg?raw";

const iconSection = (svg: string, cls: string) =>
  svg.replace("<svg", `<svg class="${cls}"`);
const downloadSimpleIcon = iconSection(
  DownloadSimpleSvg,
  "size-8 text-muted-foreground",
);
const usersThreeIcon = iconSection(
  UsersThreeSvg,
  "size-8 text-muted-foreground",
);
const buildingIcon = iconSection(BuildingSvg, "size-8 text-muted-foreground");
const checkMuted = iconSection(
  CheckSvg,
  "size-5 shrink-0 text-quaternary mt-px",
);
const checkAccent = iconSection(CheckSvg, "size-5 shrink-0 text-accent mt-px");

const __ = await getTranslator(Astro.currentLocale);

const clientLogos = [
  { src: "/clients/ahrefs.svg", alt: "Ahrefs" },
  { src: "/clients/lucis.svg", alt: "Lucis" },
  { src: "/clients/filz.svg", alt: "Filz" },
  { src: "/clients/wolfia.svg", alt: "Wolfia" },
  { src: "/clients/trace_for_good.webp", alt: "Trace for Good" },
  { src: "/clients/tinfoil.svg", alt: "Tinfoil" },
  { src: "/clients/typebot.svg", alt: "Typebot" },
  { src: "/clients/jimo.svg", alt: "Jimo" },
  { src: "/clients/normal.svg", alt: "Normal" },
];

const openSourceFeatures = [
  __("Self-hosted compliance platform"),
  __("Framework tracking (SOC 2, ISO 27001, GDPR...)"),
  __("Automated evidence collection"),
  __("Community support"),
];

const fullServiceFeatures = [
  __("Dedicated compliance officer"),
  __("Gap assessment & risk analysis"),
  __("Vendor reviews & custom policies"),
  __("Audit prep & representation"),
  __("12 months compliance service included"),
];

const enterpriseFeatures = [
  __("Bring your own cloud"),
  __("Forward deployed compliance engineer"),
  __("Custom frameworks"),
  __("Physical presence during audits"),
];
---

<section class="bg-level-0 flex flex-col items-center">
  <!-- Hero -->
  <div class="flex w-full max-w-[1080px] items-end gap-10 overflow-clip">
    <!-- Left decorative vertical line -->
    <div
      class="animate-fade-in animation-delay-800 flex hidden items-end self-stretch min-[1080px]:flex"
    >
      <div
        class="h-full max-h-32 w-px bg-linear-to-t from-[#ecefe8] to-transparent"
      >
      </div>
    </div>

    <!-- Hero content -->
    <div
      class="flex min-w-0 flex-1 flex-col items-stretch gap-6 px-6 pt-16 pb-10 min-[1080px]:px-0 sm:flex-row sm:items-end"
    >
      <div class="flex min-w-0 flex-1 flex-col gap-6">
        <h1
          class="text-foreground animate-slide-in text-[36px] leading-none font-medium tracking-[-1.44px] sm:text-[48px]"
        >
          {__("Get audit-ready.")}
        </h1>
        <p
          class="text-muted-foreground animate-slide-in animation-delay-100 text-lg leading-[1.5] sm:max-w-[530px]"
        >
          {__("We handle everything from gap assessment to audit day.")}
          <br class="hidden min-[1080px]:block" />{
            __("Pick the plan that fits, or deploy our open-source platform.")
          }
        </p>
      </div>

      <div
        class="animate-slide-in animation-delay-200 flex min-w-0 flex-1 flex-col items-start gap-4 sm:items-center"
      >
        <p
          class="text-muted-foreground text-xs leading-[1.3] whitespace-nowrap"
        >
          {__("They trust us with their compliance")}
        </p>
        <div class="relative w-full overflow-hidden">
          <LogosScroll class="flex h-5 items-center" client:load>
            {
              clientLogos.map((logo) => (
                <span class="flex items-center px-2.5">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="h-5 w-auto shrink-0 opacity-60"
                    loading="lazy"
                  />
                </span>
              ))
            }
          </LogosScroll>
          <div
            class="from-level-0 pointer-events-none absolute top-0 bottom-0 left-0 w-12 bg-linear-to-r to-transparent"
          >
          </div>
          <div
            class="from-level-0 pointer-events-none absolute top-0 right-0 bottom-0 w-12 bg-linear-to-l to-transparent"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- Right decorative vertical line -->
    <div
      class="animate-fade-in animation-delay-800 flex hidden items-end self-stretch min-[1080px]:flex"
    >
      <div
        class="h-full max-h-32 w-px bg-linear-to-t from-[#ecefe8] to-transparent"
      >
      </div>
    </div>
  </div>

  <!-- Cards row with decorative side lines -->
  <div class="w-full overflow-clip">
    <!-- Three pricing cards -->
    <div
      class="relative mx-auto flex w-full max-w-[1080px] flex-col items-stretch min-[860px]:flex-row"
    >
      <!-- Left decorative horizontal lines -->
      <div
        class="animate-fade-in animation-delay-800 absolute top-0 right-full bottom-0 hidden w-32 flex-col justify-between min-[1080px]:flex"
      >
        <div class="h-px w-full bg-linear-to-l from-[#ecefe8] to-transparent">
        </div>
        <div class="h-px w-full bg-linear-to-l from-[#ecefe8] to-transparent">
        </div>
      </div>
      <!-- Open Source Card -->
      <div
        class="border-border-low animate-slide-in animation-delay-200 flex flex-1 flex-col gap-16 border p-6 min-[860px]:border-r-0 min-[1080px]:p-10"
      >
        <div class="flex flex-col gap-6">
          <Fragment set:html={downloadSimpleIcon} />
          <p
            class="text-muted-foreground text-sm font-medium tracking-[-0.14px]"
          >
            {__("Open Source")}
          </p>
          <p
            class="text-muted-foreground text-[40px] leading-none font-medium tracking-[-1px]"
          >
            {__("Free")}
          </p>
        </div>

        <div class="flex flex-1 flex-col gap-6">
          <div class="flex flex-col gap-6">
            <p class="text-muted-foreground text-lg leading-[1.5]">
              {__("Run compliance on your own terms.")}
            </p>
            <div class="bg-border-low h-px w-full"></div>
          </div>

          <div class="flex flex-1 flex-col gap-3">
            {
              openSourceFeatures.map((feature) => (
                <div class="flex items-start gap-2">
                  <Fragment set:html={checkMuted} />
                  <span class="text-muted-foreground text-base leading-normal">
                    {feature}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <a
          href={getLink(Astro, "/docs/self-hosting/docker-compose")}
          class="border-border-mid text-foreground hover:bg-highlight flex h-8 w-full items-center justify-center rounded-full border text-base font-medium tracking-[-0.45px] transition-colors"
        >
          {__("Deploy for free")}
        </a>
      </div>

      <!-- Full Service Card -->
      <div
        class="border-border-low animate-slide-in animation-delay-300 relative flex flex-1 flex-col gap-16 overflow-clip border p-6 min-[1080px]:p-10"
      >
        <!-- Green glow background -->
        <div
          class="bg-active/40 pointer-events-none absolute size-[518px] rounded-full blur-[100px]"
          style="left: calc(50% + 29px); top: calc(50% + 103px); transform: translate(-50%, -50%); animation: glowEntry 1.5s ease-out forwards, glowDrift 4s ease-in-out infinite;"
        >
        </div>

        <div class="relative flex flex-col gap-6">
          <div class="flex items-start justify-between">
            <Fragment set:html={usersThreeIcon} />
            <span
              class="bg-active text-success rounded-full px-2 py-0.5 text-xs"
            >
              {__("Recommended")}
            </span>
          </div>
          <p
            class="text-muted-foreground text-sm font-medium tracking-[-0.14px]"
          >
            {__("Full Service")}
          </p>
          <div class="flex items-center gap-[9px]">
            <p
              class="text-foreground text-[40px] leading-none font-medium tracking-[-1px]"
            >
              $10,000
            </p>
            <div class="text-muted-foreground text-xs leading-[1.3]">
              <p>{__("Starting at")}</p>
              <p>{__("Billed annually")}</p>
            </div>
          </div>
        </div>

        <div class="relative flex flex-col gap-6">
          <div class="flex flex-col gap-6">
            <p class="text-muted-foreground text-lg leading-[1.5]">
              {__("Our experts handle your compliance.")}
            </p>
            <div class="bg-border-low h-px w-full"></div>
          </div>

          <div class="flex flex-col gap-3">
            {
              fullServiceFeatures.map((feature) => (
                <div class="flex items-start gap-2">
                  <Fragment set:html={checkAccent} />
                  <span class="text-foreground text-base leading-normal tracking-[-0.14px]">
                    {feature}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="bg-foreground text-primary-foreground hover:bg-foreground/90 relative flex h-8 w-full items-center justify-center rounded-full text-base font-semibold tracking-[-0.45px] transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>

      <!-- Enterprise Card -->
      <div
        class="border-border-low animate-slide-in animation-delay-400 flex flex-1 flex-col gap-16 border p-6 min-[860px]:border-l-0 min-[1080px]:p-10"
      >
        <div class="flex flex-col gap-6">
          <Fragment set:html={buildingIcon} />
          <p
            class="text-muted-foreground text-sm font-medium tracking-[-0.14px]"
          >
            {__("Enterprise")}
          </p>
          <p
            class="text-foreground text-[40px] leading-none font-medium tracking-[-1px]"
          >
            {__("Custom")}
          </p>
        </div>

        <div class="flex flex-1 flex-col gap-6">
          <div class="flex flex-col gap-6">
            <p class="text-muted-foreground text-lg leading-[1.5]">
              {__("Built around your organization.")}
            </p>
            <div class="bg-border-low h-px w-full"></div>
          </div>

          <div class="flex flex-1 flex-col gap-3">
            {
              enterpriseFeatures.map((feature) => (
                <div class="flex items-start gap-2">
                  <Fragment set:html={checkAccent} />
                  <span class="text-foreground text-base leading-normal tracking-[-0.14px]">
                    {feature}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="border-border-mid text-foreground hover:bg-highlight flex h-8 w-full items-center justify-center rounded-full border text-base font-medium tracking-[-0.45px] transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>
      <!-- Right decorative horizontal lines -->
      <div
        class="animate-fade-in animation-delay-800 absolute top-0 bottom-0 left-full hidden w-32 flex-col justify-between min-[1080px]:flex"
      >
        <div class="h-px w-full bg-linear-to-r from-[#ecefe8] to-transparent">
        </div>
        <div class="h-px w-full bg-linear-to-r from-[#ecefe8] to-transparent">
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom decorative vertical lines -->
  <div
    class="animate-fade-in animation-delay-800 hidden h-32 w-full max-w-[1080px] justify-between overflow-clip min-[1080px]:flex"
  >
    <div class="h-full w-px bg-linear-to-b from-[#ecefe8] to-transparent"></div>
    <div class="h-full w-px bg-linear-to-b from-[#ecefe8] to-transparent"></div>
  </div>
</section>
