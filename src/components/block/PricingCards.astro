---
import { getTranslator, getLink } from "../../lib/i18n.ts";
import LogosScroll from "../LogosScroll.svelte";

import DownloadSimpleSvg from "@phosphor-icons/core/assets/light/download-simple-light.svg?raw";
import UsersThreeSvg from "@phosphor-icons/core/assets/light/users-three-light.svg?raw";
import BuildingSvg from "@phosphor-icons/core/assets/light/building-light.svg?raw";
import CheckSvg from "@phosphor-icons/core/assets/light/check-light.svg?raw";

const iconSection = (svg: string, cls: string) => svg.replace("<svg", `<svg class="${cls}"`);
const downloadSimpleIcon = iconSection(DownloadSimpleSvg, "size-8 text-muted-foreground");
const usersThreeIcon = iconSection(UsersThreeSvg, "size-8 text-muted-foreground");
const buildingIcon = iconSection(BuildingSvg, "size-8 text-muted-foreground");
const checkMuted = iconSection(CheckSvg, "size-5 shrink-0 text-quaternary mt-px");
const checkAccent = iconSection(CheckSvg, "size-5 shrink-0 text-accent mt-px");

const __ = await getTranslator(Astro.currentLocale);

const clientLogos = [
  { src: "/clients/ahrefs.svg", alt: "Ahrefs" },
  { src: "/clients/lucis.svg", alt: "Lucis" },
  { src: "/clients/filz.svg", alt: "Filz" },
  { src: "/clients/wolfia.svg", alt: "Wolfia" },
  { src: "/clients/trace_for_good.webp", alt: "Trace for Good" },
  { src: "/clients/tinfoil.svg", alt: "Tinfoil" },
  { src: "/clients/typebot.svg", alt: "Typebot" },
  { src: "/clients/jimo.svg", alt: "Jimo" },
  { src: "/clients/normal.svg", alt: "Normal" },
];

const openSourceFeatures = [
  __("Self-hosted compliance platform"),
  __("Framework tracking (SOC 2, ISO 27001, GDPR...)"),
  __("Automated evidence collection"),
  __("Community support"),
];

const fullServiceFeatures = [
  __("Dedicated compliance officer"),
  __("Gap assessment & risk analysis"),
  __("Vendor reviews & custom policies"),
  __("Audit prep & representation"),
  __("12 months compliance service included"),
];

const enterpriseFeatures = [
  __("Bring your own cloud"),
  __("Forward deployed compliance engineer"),
  __("Custom frameworks"),
  __("Physical presence during audits"),
];
---

<section class="bg-level-0 flex flex-col items-center">
  <!-- Hero -->
  <div class="flex gap-10 items-end overflow-clip max-w-[1080px] w-full">
    <!-- Left decorative vertical line -->
    <div class="self-stretch flex items-end hidden min-[1080px]:flex animate-fade-in animation-delay-800">
      <div class="w-px h-full max-h-32 bg-linear-to-t from-[#ecefe8] to-transparent"></div>
    </div>

    <!-- Hero content -->
    <div class="flex flex-1 flex-col sm:flex-row gap-6 items-stretch sm:items-end min-w-0 pb-10 pt-16 px-6 min-[1080px]:px-0">
      <div class="flex flex-col gap-6 flex-1 min-w-0">
        <h1 class="text-[36px] sm:text-[48px] font-medium leading-none tracking-[-1.44px] text-foreground animate-slide-in">
          {__("Get audit-ready.")}
        </h1>
        <p class="text-lg leading-[1.5] text-muted-foreground sm:max-w-[530px] animate-slide-in animation-delay-100">
          {__("We handle everything from gap assessment to audit day.")} <br class="hidden min-[1080px]:block" />{__("Pick the plan that fits, or deploy our open-source platform.")}
        </p>
      </div>

      <div class="flex flex-1 flex-col gap-4 items-start sm:items-center min-w-0 animate-slide-in animation-delay-200">
        <p class="text-xs leading-[1.3] text-muted-foreground whitespace-nowrap">
          {__("They trust us with their compliance")}
        </p>
        <div class="w-full relative overflow-hidden">
          <LogosScroll class="flex h-5 items-center" client:load>
            {clientLogos.map((logo) => (
              <span class="px-2.5 flex items-center">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-5 w-auto shrink-0 opacity-60"
                  loading="lazy"
                />
              </span>
            ))}
          </LogosScroll>
          <div class="absolute left-0 top-0 bottom-0 w-12 bg-linear-to-r from-level-0 to-transparent pointer-events-none"></div>
          <div class="absolute right-0 top-0 bottom-0 w-12 bg-linear-to-l from-level-0 to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>

    <!-- Right decorative vertical line -->
    <div class="self-stretch flex items-end hidden min-[1080px]:flex animate-fade-in animation-delay-800">
      <div class="w-px h-full max-h-32 bg-linear-to-t from-[#ecefe8] to-transparent"></div>
    </div>
  </div>

  <!-- Cards row with decorative side lines -->
  <div class="w-full overflow-clip">
    <!-- Three pricing cards -->
    <div class="relative flex flex-col min-[860px]:flex-row items-stretch max-w-[1080px] w-full mx-auto">
      <!-- Left decorative horizontal lines -->
      <div class="absolute right-full top-0 bottom-0 w-32 flex-col justify-between hidden min-[1080px]:flex animate-fade-in animation-delay-800">
        <div class="h-px w-full bg-linear-to-l from-[#ecefe8] to-transparent"></div>
        <div class="h-px w-full bg-linear-to-l from-[#ecefe8] to-transparent"></div>
      </div>
      <!-- Open Source Card -->
      <div class="flex-1 border-l border-t border-b border-r min-[860px]:border-r-0 border-border-low p-6 min-[1080px]:p-10 flex flex-col gap-16 animate-slide-in animation-delay-200">
        <div class="flex flex-col gap-6">
          <Fragment set:html={downloadSimpleIcon} />
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Open Source")}
          </p>
          <p class="text-[40px] font-medium text-muted-foreground tracking-[-1px] leading-none">
            {__("Free")}
          </p>
        </div>

        <div class="flex flex-col gap-6 flex-1">
          <div class="flex flex-col gap-6">
            <p class="text-lg text-muted-foreground leading-[1.5]">
              {__("Run compliance on your own terms.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3 flex-1">
            {openSourceFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <Fragment set:html={checkMuted} />
                <span class="text-base text-muted-foreground leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/docs/self-hosting/docker-compose")}
          class="flex items-center justify-center h-8 w-full rounded-full border border-border-mid text-base font-medium tracking-[-0.45px] text-foreground hover:bg-highlight transition-colors"
        >
          {__("Deploy for free")}
        </a>
      </div>

      <!-- Full Service Card -->
      <div class="flex-1 border border-border-low p-6 min-[1080px]:p-10 flex flex-col gap-16 relative overflow-clip animate-slide-in animation-delay-300">
        <!-- Green glow background -->
        <div
          class="absolute size-[518px] rounded-full bg-[#e4f7c7]/40 blur-[100px] pointer-events-none"
          style="left: calc(50% + 29px); top: calc(50% + 103px); transform: translate(-50%, -50%); animation: glowEntry 1.5s ease-out forwards, glowDrift 4s ease-in-out infinite;"
        ></div>

        <div class="flex flex-col gap-6 relative">
          <div class="flex items-start justify-between">
            <Fragment set:html={usersThreeIcon} />
            <span class="bg-active text-success text-xs px-2 py-0.5 rounded-full">
              {__("Recommended")}
            </span>
          </div>
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Full Service")}
          </p>
          <div class="flex gap-[9px] items-center">
            <p class="text-[40px] font-medium text-foreground tracking-[-1px] leading-none">
              $8,000
            </p>
            <div class="text-xs leading-[1.3] text-muted-foreground">
              <p>{__("Starting at")}</p>
              <p>{__("Billed annually")}</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-6 relative">
          <div class="flex flex-col gap-6">
            <p class="text-lg text-muted-foreground leading-[1.5]">
              {__("Our experts handle your compliance.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3">
            {fullServiceFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <Fragment set:html={checkAccent} />
                <span class="text-base text-foreground tracking-[-0.14px] leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="relative flex items-center justify-center h-8 w-full rounded-full bg-foreground text-base font-semibold tracking-[-0.45px] text-primary-foreground hover:bg-foreground/90 transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>

      <!-- Enterprise Card -->
      <div class="flex-1 border-r border-t border-b border-l min-[860px]:border-l-0 border-border-low p-6 min-[1080px]:p-10 flex flex-col gap-16 animate-slide-in animation-delay-400">
        <div class="flex flex-col gap-6">
          <Fragment set:html={buildingIcon} />
          <p class="text-sm font-medium text-muted-foreground tracking-[-0.14px]">
            {__("Enterprise")}
          </p>
          <p class="text-[40px] font-medium text-foreground tracking-[-1px] leading-none">
            {__("Custom")}
          </p>
        </div>

        <div class="flex flex-col gap-6 flex-1">
          <div class="flex flex-col gap-6">
            <p class="text-lg text-muted-foreground leading-[1.5]">
              {__("Built around your organization.")}
            </p>
            <div class="h-px bg-border-low w-full"></div>
          </div>

          <div class="flex flex-col gap-3 flex-1">
            {enterpriseFeatures.map((feature) => (
              <div class="flex gap-2 items-start">
                <Fragment set:html={checkAccent} />
                <span class="text-base text-foreground tracking-[-0.14px] leading-normal">
                  {feature}
                </span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={getLink(Astro, "/contact")}
          class="flex items-center justify-center h-8 w-full rounded-full border border-border-mid text-base font-medium tracking-[-0.45px] text-foreground hover:bg-highlight transition-colors"
        >
          {__("Talk to an advisor")}
        </a>
      </div>
      <!-- Right decorative horizontal lines -->
      <div class="absolute left-full top-0 bottom-0 w-32 flex-col justify-between hidden min-[1080px]:flex animate-fade-in animation-delay-800">
        <div class="h-px w-full bg-linear-to-r from-[#ecefe8] to-transparent"></div>
        <div class="h-px w-full bg-linear-to-r from-[#ecefe8] to-transparent"></div>
      </div>
    </div>
  </div>

  <!-- Bottom decorative vertical lines -->
  <div class="justify-between max-w-[1080px] w-full h-32 overflow-clip hidden min-[1080px]:flex animate-fade-in animation-delay-800">
    <div class="w-px h-full bg-linear-to-b from-[#ecefe8] to-transparent"></div>
    <div class="w-px h-full bg-linear-to-b from-[#ecefe8] to-transparent"></div>
  </div>
</section>
