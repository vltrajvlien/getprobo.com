---
import Layout from "../../layouts/Layout.astro";
import FrameworkBadge from "../../components/FrameworkBadge.svelte";
import { Image } from "astro:assets";
import ProboLogo from "../../assets/probo-logo.svg";
import ProboLogoOnly from "../../assets/probo-logo-only.svg";
import TrustCenterExample from "../../assets/trust-center-example.png";

const iso27001Badges = [{ label: "ISO 27001", badge: "ISO27001" }];
---

<Layout
  title="ISO/IEC 27001 - What's Next"
  description="ISO/IEC 27001 Communication Kit - Learn how to communicate your ISO 27001 certification effectively."
  noFrameworks={true}
>
  <!-- Fixed Table of Contents - Left Side -->
  <aside
    class="fixed top-0 bottom-0 left-4 z-10 hidden w-64 items-center justify-center px-4 xl:flex"
  >
    <nav
      class="bg-level-1 border-border-low space-y-4 rounded-lg border p-5 text-sm"
    >
      <!-- Communication Guidelines -->
      <div>
        <a
          href="#communication-guidelines"
          class="text-foreground hover:text-primary font-medium transition-colors"
          >Communication Guidelines</a
        >
        <ul class="text-muted-foreground mt-2 ml-3 space-y-1">
          <li>
            <a
              href="#trust-center"
              class="hover:text-foreground transition-colors">Trust center</a>
          </li>
          <li>
            <a
              href="#achievement"
              class="hover:text-foreground transition-colors">Achievement</a>
          </li>
          <li>
            <a
              href="#value-for-customers"
              class="hover:text-foreground transition-colors"
              >Value for Customers</a>
          </li>
        </ul>
      </div>
      <!-- Linkedin post & blog article -->
      <div>
        <a
          href="#linkedin-blog"
          class="text-foreground hover:text-primary font-medium transition-colors"
          >Linkedin post & blog article content</a
        >
        <ul class="text-muted-foreground mt-2 ml-3 space-y-1">
          <li>
            <a
              href="#linkedin-post"
              class="hover:text-foreground transition-colors">Linkedin post</a>
          </li>
          <li>
            <a
              href="#blog-article"
              class="hover:text-foreground transition-colors">Blog article</a>
          </li>
        </ul>
      </div>
      <!-- Assets for your website -->
      <div>
        <a
          href="#assets"
          class="text-foreground hover:text-primary font-medium transition-colors"
          >Assets for your website</a
        >
        <ul class="text-muted-foreground mt-2 ml-3 space-y-1">
          <li>
            <a
              href="#compliance-badges"
              class="hover:text-foreground transition-colors"
              >Compliance Badges for ISO 27001</a>
          </li>
          <li>
            <a
              href="#probo-logo"
              class="hover:text-foreground transition-colors">Probo logo</a>
          </li>
        </ul>
      </div>
      <!-- Turn compliance into business growth -->
      <div>
        <a
          href="#business-growth"
          class="text-foreground hover:text-primary font-medium transition-colors"
          >Turn compliance into business growth</a
        >
      </div>
    </nav>
  </aside>

  <!-- Hero Banner -->
  <div
    class="w-full py-16 sm:py-24"
    style="background: linear-gradient(135deg, #1a2e1a 0%, #2d4a2d 50%, #1a2e1a 100%);"
  >
    <div class="container max-w-[920px] text-center">
      <div
        class="mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-2"
        style="background-color: rgba(196, 240, 66, 0.1); border-color: rgba(196, 240, 66, 0.3);"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#C4F042"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
          ></path>
          <path d="m9 12 2 2 4-4"></path>
        </svg>
        <span class="text-sm font-medium" style="color: #C4F042;"
          >ISO/IEC 27001 - What's Next</span
        >
      </div>
      <h1
        class="animate-slide-in mb-8 font-bold"
        style="color: #ffffff; font-size: clamp(25px, 4vw, 3rem);"
      >
        Turn Your ISO 27001 Certification into a Trust Asset
      </h1>
      <p
        class="animate-slide-in animation-delay-100 mx-auto max-w-3xl text-xl sm:text-2xl"
        style="color: #ffffff;"
      >
        Congratulations on achieving your ISO 27001 certification! This is a
        major milestone worth celebrating.
      </p>
      <p
        class="animate-slide-in animation-delay-100 mx-auto mt-4 max-w-3xl text-xl sm:text-2xl"
        style="color: #c4abab;"
      >
        Now is the time to share it with your customers, prospects, and
        stakeholders.
      </p>
    </div>
  </div>

  <main class="container max-w-[920px] py-10 sm:py-20">
    <div class="space-y-16">
      <!-- Communication Guidelines Section -->
      <section
        id="communication-guidelines"
        class="animate-slide-in animation-delay-200"
      >
        <h2 class="text-h4 mb-10 font-medium">Communication Guidelines</h2>

        <!-- Trust center -->
        <div id="trust-center" class="mb-10">
          <div class="mb-6 flex items-center gap-3">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl"
              style="background-color: #000000; border: 1px solid #C4F042;"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#C4F042"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                <path d="M9 9h6"></path>
                <path d="M9 13h6"></path>
                <path d="M9 17h6"></path>
              </svg>
            </div>
            <h3 class="text-lg font-medium">Trust center</h3>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div
              class="overflow-hidden rounded-xl border p-5"
              style="border-color: #e5e7eb;"
            >
              <p class="text-foreground mb-4">
                Create or update your Trust Center to showcase your new ISO
                27001 certification.
              </p>
              <p class="text-muted-foreground mb-3">
                You don't have a <a
                  href="https://compliance.getprobo.com/overview"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline">Trust Center</a
                > yet?
              </p>
              <p class="text-muted-foreground">
                Reach out to the Probo team, we will get yours for free.
              </p>
            </div>
            <div
              class="overflow-hidden rounded-xl border p-4"
              style="border-color: #e5e7eb;"
            >
              <p class="text-xxs text-muted-foreground mb-2">Example</p>
              <Image
                src={TrustCenterExample}
                alt="Trust Center Example"
                class="rounded-lg"
              />
            </div>
          </div>
        </div>

        <!-- Achievement -->
        <div id="achievement" class="mb-10">
          <div class="mb-6 flex items-center gap-3">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl"
              style="background-color: #000000; border: 1px solid #C4F042;"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#C4F042"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                ></path>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
            </div>
            <h3 class="text-lg font-medium">Achievement</h3>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div
              class="overflow-hidden rounded-xl border"
              style="border-color: #bbf7d0;"
            >
              <div
                class="flex items-center gap-2 px-4 py-3"
                style="background-color: #f0fdf4;"
              >
                <div
                  class="flex h-6 w-6 items-center justify-center rounded-lg"
                  style="background-color: #22c55e;"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 6 9 17l-5-5"></path>
                  </svg>
                </div>
                <span class="font-medium" style="color: #166534;"
                  >What you can say</span
                >
              </div>
              <div class="space-y-3 p-5">
                <div class="flex items-start gap-2">
                  <span
                    class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                    style="background-color: #22c55e;"></span>
                  <span class="text-foreground"
                    >"We are ISO/IEC 27001 certified."</span
                  >
                </div>
                <div class="flex items-start gap-2">
                  <span
                    class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                    style="background-color: #22c55e;"></span>
                  <span class="text-foreground"
                    >"Our Information Security Management System (ISMS) has been
                    certified as conforming to the ISO/IEC 27001 standard."</span
                  >
                </div>
                <div class="flex items-start gap-2">
                  <span
                    class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                    style="background-color: #22c55e;"></span>
                  <span class="text-foreground"
                    >"Our ISO/IEC 27001 certification ISMS demonstrates our
                    commitment to managing information security risks and
                    protecting customer data."</span
                  >
                </div>
              </div>
            </div>
            <div
              class="overflow-hidden rounded-xl border"
              style="border-color: #fecaca;"
            >
              <div
                class="flex items-center gap-2 px-4 py-3"
                style="background-color: #fef2f2;"
              >
                <div
                  class="flex h-6 w-6 items-center justify-center rounded-lg"
                  style="background-color: #ef4444;"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                  </svg>
                </div>
                <span class="font-medium" style="color: #991b1b;"
                  >What you can't say</span
                >
              </div>
              <div class="space-y-4 p-5">
                <div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style="background-color: #ef4444;"></span>
                    <span class="font-bold" style="color: #dc2626;"
                      >DO NOT USE ISO OFFICIAL LOGO</span
                    >
                  </div>
                  <div
                    class="mt-1 ml-4 border-l-2 pl-3"
                    style="border-color: #fecaca;"
                  >
                    <span class="text-sm" style="color: #dc2626;"
                      >→ ISO has a strict <a
                        href="https://www.iso.org/iso-name-and-logo.html"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline">trademark policy</a
                      >. Instead you can use the logo we offer you: <a
                        href="#compliance-badges"
                        class="underline">here</a
                      >.</span
                    >
                  </div>
                </div>
                <div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style="background-color: #ef4444;"></span>
                    <span class="text-foreground"
                      >"We are ISO 27001 certified across the entire company."</span
                    >
                  </div>
                  <div
                    class="mt-1 ml-4 border-l-2 pl-3"
                    style="border-color: #fecaca;"
                  >
                    <span class="text-sm" style="color: #dc2626;"
                      >→ Only claim certification for the exact scope defined in
                      your certificate.</span
                    >
                  </div>
                </div>
                <div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style="background-color: #ef4444;"></span>
                    <span class="text-foreground"
                      >"All our products and services are ISO 27001 certified."</span
                    >
                  </div>
                  <div
                    class="mt-1 ml-4 border-l-2 pl-3"
                    style="border-color: #fecaca;"
                  >
                    <span class="text-sm" style="color: #dc2626;"
                      >→ Certification applies to the ISMS scope, not
                      automatically to everything you do.</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Value for Customers -->
        <div id="value-for-customers" class="mb-10">
          <div class="mb-6 flex items-center gap-3">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-xl"
              style="background-color: #000000; border: 1px solid #C4F042;"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#C4F042"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <h3 class="text-lg font-medium">Value for Customers</h3>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div
              class="overflow-hidden rounded-xl border"
              style="border-color: #bbf7d0;"
            >
              <div
                class="flex items-center gap-2 px-4 py-3"
                style="background-color: #f0fdf4;"
              >
                <div
                  class="flex h-6 w-6 items-center justify-center rounded-lg"
                  style="background-color: #22c55e;"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 6 9 17l-5-5"></path>
                  </svg>
                </div>
                <span class="font-medium" style="color: #166534;"
                  >What you can say</span
                >
              </div>
              <div class="space-y-3 p-5">
                <div class="flex items-start gap-2">
                  <span
                    class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                    style="background-color: #22c55e;"></span>
                  <span class="text-foreground"
                    >"ISO/IEC 27001 certification means stronger data
                    protection, reduced risk, and a trusted partner that takes
                    information security seriously."</span
                  >
                </div>
                <div class="flex items-start gap-2">
                  <span
                    class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                    style="background-color: #22c55e;"></span>
                  <span class="text-foreground"
                    >"This certification reflects our long-term commitment to
                    security governance and operational discipline."</span
                  >
                </div>
              </div>
            </div>
            <div
              class="overflow-hidden rounded-xl border"
              style="border-color: #fecaca;"
            >
              <div
                class="flex items-center gap-2 px-4 py-3"
                style="background-color: #fef2f2;"
              >
                <div
                  class="flex h-6 w-6 items-center justify-center rounded-lg"
                  style="background-color: #ef4444;"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="white"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                  </svg>
                </div>
                <span class="font-medium" style="color: #991b1b;"
                  >What you can't say</span
                >
              </div>
              <div class="space-y-4 p-5">
                <div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style="background-color: #ef4444;"></span>
                    <span class="text-foreground"
                      >"This certification means breaches cannot happen."</span
                    >
                  </div>
                  <div
                    class="mt-1 ml-4 border-l-2 pl-3"
                    style="border-color: #fecaca;"
                  >
                    <span class="text-sm" style="color: #dc2626;"
                      >→ ISO/IEC 27001 validates a management system and
                      controls, not absolute security.</span
                    >
                  </div>
                </div>
                <div>
                  <div class="flex items-start gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full"
                      style="background-color: #ef4444;"></span>
                    <span class="text-foreground"
                      >"We are ISO 27001 compliant forever."</span
                    >
                  </div>
                  <div
                    class="mt-1 ml-4 border-l-2 pl-3"
                    style="border-color: #fecaca;"
                  >
                    <span class="text-sm" style="color: #dc2626;"
                      >→ ISO/IEC 27001 certification requires continuous
                      operation, annual surveillance audits, and
                      recertification.</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Linkedin post & blog article content Section -->
      <section id="linkedin-blog" class="animate-slide-in animation-delay-300">
        <h2 class="text-h4 mb-10 font-medium">
          Linkedin post & blog article content
        </h2>

        <h3
          id="linkedin-post"
          class="mt-10 mb-4 flex items-center gap-2 text-lg font-medium"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#0A66C2">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          Linkedin post
        </h3>
        <p class="text-muted-foreground mb-4">
          It is now a good time to inform your customers and prospects about
          your new milestone.
        </p>
        <p class="text-muted-foreground mb-4">
          We recommend you to start by posting it on your Linkedin page (if you
          tag Probo we will be glad to share it).
        </p>
        <p class="text-muted-foreground mb-6">
          Here is an example you can use:
        </p>

        <div
          class="bg-level-1 border-border-low relative rounded-lg border p-6"
          id="linkedin-content"
        >
          <button
            class="hover:bg-level-2 copy-btn absolute top-4 right-4 rounded-md p-2 transition-colors"
            data-target="linkedin-content"
            title="Copy to clipboard"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-muted-foreground"
            >
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
              ></path>
            </svg>
          </button>
          <p class="mb-4 font-medium">🔐 We're Now ISO 27001 Certified</p>
          <p class="text-muted-foreground mb-4">
            Security and trust have always been core to how we build and
            operate. Today, we're proud to share an important milestone: we've
            achieved <strong>ISO/IEC 27001 certification</strong>, the
            international standard for information security management system
            (ISMS).
          </p>
          <p class="text-muted-foreground mb-4">
            This isn't just about passing an audit. It reflects the systems,
            processes, and culture we've put in place to manage risk, protect
            sensitive information, and continuously improve how we safeguard our
            customers' data.
          </p>
          <p class="text-muted-foreground mb-2">
            For our customers and partners, this means:
          </p>
          <ul
            class="text-muted-foreground mb-4 list-inside list-disc space-y-1"
          >
            <li>A structured, risk-based approach to information security</li>
            <li>Strong governance across people, processes, and technology</li>
            <li>An ongoing commitment to protecting what matters most</li>
          </ul>
          <p class="text-muted-foreground mb-4">
            👏 A big thank you to <strong>@Probo</strong>, whose platform and
            team made the entire ISO 27001 journey significantly smoother.
          </p>
          <p class="text-muted-foreground">
            And of course, huge thanks to everyone internally who contributed to
            making this happen.
          </p>
        </div>

        <!-- White Template for LinkedIn -->
        <div class="bg-level-1 border-border-low mt-8 rounded-lg border p-6">
          <p class="text-foreground mb-2 font-medium">
            Linkedin asset template
          </p>
          <p class="text-muted-foreground mb-4">
            You can download and customize this template to visually support
            your post, if needed.
          </p>
          <div
            class="flex flex-col items-start gap-4 sm:flex-row sm:items-center"
          >
            <img
              src="/linkedin-template-iso27001.png"
              alt="LinkedIn post template for ISO 27001 announcement"
              class="border-border rounded-lg border"
              style="width: 500px;"
            />
            <a
              href="/linkedin-template-iso27001.png"
              download="linkedin-template-iso27001.png"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center gap-2 rounded-md px-4 py-2 transition-colors"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Download template
            </a>
          </div>
        </div>

        <h3
          id="blog-article"
          class="mt-10 mb-4 flex items-center gap-2 text-lg font-medium"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
