---
import Layout from "../../layouts/Layout.astro";
import { getTranslator } from "../../lib/i18n.ts";
import { Image } from "astro:assets";
import AntoinePortrait from "../../assets/about/antoine-bourchardy.png";
const __ = await getTranslator(Astro.currentLocale);

const tableOfContents = [
  { id: "intro", label: "Why Choosing the Right Framework Matters" },
  { id: "factors", label: "The 6 Factors That Determine Your Requirements" },
  { id: "soc2", label: "When You Need SOC 2" },
  { id: "gdpr", label: "When You Need GDPR" },
  { id: "hipaa", label: "When You Need HIPAA" },
  { id: "pci-dss", label: "When You Need PCI DSS" },
  { id: "multiple-frameworks", label: "When You Need Multiple Frameworks" },
  { id: "examples", label: "Real-World Examples" },
  { id: "validate", label: "How to Validate Your Requirements" },
  { id: "conclusion", label: "Conclusion" },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Which Compliance Framework Do You Need? A Guide by Business Type",
  description:
    "Not sure if you need SOC 2, GDPR, HIPAA, or PCI DSS? Use our guide to identify the right compliance frameworks based on your business type, customers, and data.",
  author: {
    "@type": "Organization",
    name: "Probo",
    url: "https://www.getprobo.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Probo",
    url: "https://www.getprobo.com",
    logo: {
      "@type": "ImageObject",
      url: "https://www.getprobo.com/probo-logo.svg",
    },
  },
  datePublished: "2026-02-12",
  dateModified: new Date().toISOString().split("T")[0],
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": "https://www.getprobo.com/hub/which-compliance-framework",
  },
  image: "https://www.getprobo.com/hub/compliance_framework_need.jpg",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.getprobo.com",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Hub",
      item: "https://www.getprobo.com/hub",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Which Compliance Framework Do You Need?",
      item: "https://www.getprobo.com/hub/which-compliance-framework",
    },
  ],
};
---

<Layout
  title={__("Which Compliance Framework Do You Need? A Guide by Business Type")}
  description={__(
    "Not sure if you need SOC 2, GDPR, HIPAA, or PCI DSS? Use our guide to identify the right compliance frameworks based on your business type, customers, and data.",
  )}
  ogImage="/hub/compliance_framework_need.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  <main class="container my-10 sm:my-20">
    <!-- Header -->
    <header class="mx-auto mb-12 max-w-[900px] text-center sm:mb-16">
      <h1
        class="text-foreground mb-6 text-[2.5rem] leading-[1.1] font-semibold tracking-[-0.02em] sm:text-[3.5rem]"
      >
        {__("Which")}
        <span class="highlight-text">{__("Compliance Framework")}</span><br />{
          __("Do You Need?")
        }
      </h1>
      <p class="text-muted-foreground mb-8 text-lg">
        {
          __(
            "A practical guide to help you identify exactly which frameworks your business needs—based on concrete attributes, not guesswork.",
          )
        }
      </p>
      <img
        src="/hub/compliance_framework_need.jpg"
        alt="Which Compliance Framework Do You Need?"
        class="mx-auto w-full max-w-[800px] rounded-2xl shadow-lg"
      />
    </header>

    <!-- Content with TOC -->
    <div class="flex flex-col gap-10 lg:flex-row lg:gap-16">
      <!-- Table of Contents - Sidebar -->
      <aside class="shrink-0 lg:w-56">
        <nav class="lg:sticky lg:top-24">
          <div class="flex flex-col gap-2">
            {
              tableOfContents.map((item) => (
                <button
                  type="button"
                  data-section={item.id}
                  class="toc-link cursor-pointer border-none bg-transparent p-0 text-left text-sm leading-5 text-[#6b716a] transition-colors hover:text-[#141e12]"
                >
                  {item.label}
                </button>
              ))
            }
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <article class="max-w-[720px] flex-1">
        <!-- Introduction -->
        <section id="intro" class="mb-12 scroll-mt-24">
          <h2
            class="text-foreground mb-6 text-2xl font-semibold tracking-[-0.01em] sm:text-[1.75rem]"
          >
            {__("Why Choosing the Right Framework Matters (And Costs Less)")}
          </h2>
          <div class="text-muted-foreground space-y-4 leading-relaxed">
            <p>
              {
                __(
                  'You just landed a meeting with your dream enterprise customer. The demo went perfectly, the champion is excited, and procurement sends over the security questionnaire. Then you see it: "Please provide your SOC 2 Type II report."',
                )
              }
            </p>
            <p>
              {
                __(
                  "Your heart sinks. You've heard of SOC 2, maybe GDPR too, but you're not entirely sure which frameworks actually apply to your business. Should you pursue all of them? Just one? And what about HIPAA—does that matter if you're not technically a \"healthcare company\"?",
                )
              }
            </p>
            <p>
              {
                __(
                  "This confusion costs startups real money and real deals. We've seen founders spend $50,000 pursuing the wrong certification, only to discover their enterprise prospects actually needed something different. Others delay compliance entirely out of analysis paralysis, watching competitors close deals they should have won.",
                )
              }
            </p>
            <p>
              {
                __(
                  "Compliance isn't a one-size-fits-all proposition. A B2B SaaS company selling to US enterprises has fundamentally different requirements than a healthcare app serving European patients. Yet many founders approach compliance like a checklist, pursuing frameworks based on what they've heard is \"standard\" rather than what their specific situation demands.",
                )
              }
            </p>
            <p>
              {
                __(
                  "The good news? Most early-stage companies need one or two frameworks to start, not five. By understanding which factors determine your requirements, you can prioritize the certification that will close deals faster while planning a realistic roadmap for additional frameworks as you grow.",
                )
              }
            </p>
          </div>
        </section>

        <!-- CTA Box - Compliance Recommender -->
        <section
          class="mb-12 rounded-2xl border border-gray-100 bg-white p-8 shadow-[0_8px_60px_rgba(0,0,0,0.12)]"
        >
          <div class="text-center">
            <h3 class="mb-3 text-xl font-semibold text-[#141e12]">
              {__("Not sure which framework you need?")}
            </h3>
            <p class="text-muted-foreground mx-auto mb-6 max-w-[500px]">
              {
                __(
                  "Use our free Compliance Framework Recommender to get a personalized assessment based on your business type, customers, and data.",
                )
              }
            </p>
            <a
              href="/hub/compliance-recommender"
              class="inline-flex items-center gap-2 rounded-full bg-[#141e12] px-6 py-3 font-medium text-[#e6ff01] shadow-lg transition-all hover:bg-[#1f2e1a] hover:shadow-xl"
            >
              {__("Get Your Free Assessment")}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- The 6 Factors -->
        <section id="factors" class="mb-12 scroll-mt-24">
          <h2
            class="text-foreground mb-6 text-2xl font-semibold tracking-[-0.01em] sm:text-[1.75rem]"
          >
            {__("The 6 Factors That Determine Your Compliance Requirements")}
          </h2>
          <div class="text-muted-foreground space-y-6 leading-relaxed">
            <p>
              {
                __(
                  "Before diving into specific frameworks, let's establish the decision criteria. These six factors will determine approximately 90% of your compliance requirements. As you read through each one, note which attributes apply to your business.",
                )
              }
            </p>

            <!-- Factor 1: Business Type -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {
                  __(
                    "1. Business Type (SaaS, Fintech, Healthcare, E-commerce, Marketplace)",
                  )
                }
              </h3>
              <p class="mb-3">
                {
                  __(
                    "Your fundamental business model shapes your baseline compliance needs. Each business type carries inherent data handling patterns and risk profiles that regulators and customers care about.",
                  )
                }
              </p>
              <ul class="ml-0 list-none space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("SaaS companies")}</strong
                    >
                    {
                      __(
                        "typically need to demonstrate they can securely handle customer data at rest and in transit. This usually means SOC 2 as a starting point, with additional frameworks layered based on the data types involved.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Fintech companies")}</strong
                    >
                    {
                      __(
                        "face a more complex landscape. Beyond general security frameworks, you're likely looking at financial services regulations, potentially PCI DSS if you touch payment card data, and state-by-state money transmitter requirements.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Healthcare technology companies")}</strong
                    >
                    {
                      __(
                        'almost always need HIPAA compliance if they handle any patient information—even if they consider themselves a "tech company that happens to serve healthcare."',
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("E-commerce and marketplace businesses")}</strong
                    >
                    {
                      __(
                        "typically need PCI DSS compliance for payment processing, plus GDPR if serving European customers. The specific requirements depend heavily on whether you process payments directly or use a third-party processor.",
                      )
                    }</span
                  >
                </li>
              </ul>
            </div>

            <!-- Factor 2: Target Customers -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {
                  __(
                    "2. Target Customers (B2B vs B2C, Enterprise vs SMB, Government)",
                  )
                }
              </h3>
              <p class="mb-3">
                {
                  __(
                    "Who writes your checks matters enormously for compliance prioritization.",
                  )
                }
              </p>
              <ul class="ml-0 list-none space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Enterprise B2B customers")}</strong
                    >
                    {
                      __(
                        "(companies with 500+ employees) almost universally require SOC 2 Type II reports before signing contracts. This isn't optional—it's a procurement checkbox.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("SMB customers")}</strong
                    >
                    {
                      __(
                        "are generally less demanding about formal certifications, though this is changing. Many SMBs now ask for SOC 2 reports, especially if they're handling sensitive data themselves.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("B2C customers")}</strong
                    >
                    {
                      __(
                        "rarely ask about your SOC 2 status, but regulators do care about how you protect consumer data. GDPR, CCPA, and other privacy regulations become more relevant here.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Government customers")}</strong
                    >
                    {
                      __(
                        "have their own framework requirements, including FedRAMP for US federal agencies and StateRAMP for state-level contracts.",
                      )
                    }</span
                  >
                </li>
              </ul>
            </div>

            <!-- Factor 3: Industry Sector -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {__("3. Industry Sector and Regulatory Environment")}
              </h3>
              <p>
                {
                  __(
                    "Some industries have mandatory compliance requirements regardless of your business model. Financial services companies must comply with regulations like GLBA, SOX (if publicly traded), and various state and federal banking regulations. Healthcare organizations face HIPAA requirements. Companies handling children's data must comply with COPPA.",
                  )
                }
              </p>
              <p class="mt-2">
                {
                  __(
                    "These aren't optional frameworks you choose—they're legal requirements based on your industry classification. If you're uncertain whether your business falls under specific industry regulations, consult with a compliance attorney before making framework decisions.",
                  )
                }
              </p>
            </div>

            <!-- Factor 4: Geographic Markets -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {__("4. Geographic Markets and Countries of Operation")}
              </h3>
              <p class="mb-3">
                {
                  __(
                    "Where your customers are located—not where your company is headquartered—determines many of your compliance obligations.",
                  )
                }
              </p>
              <ul class="ml-0 list-none space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("European Union presence")}</strong
                    >
                    {
                      __(
                        "triggers GDPR requirements. This applies if you have EU customers, EU employees, or process data about EU residents—even if your company is based in the United States.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("United States operations")}</strong
                    >
                    {
                      __(
                        "may trigger state-specific privacy laws like CCPA (California), VCDPA (Virginia), or CPA (Colorado). These requirements are expanding rapidly.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Global operations")}</strong
                    >
                    {
                      __(
                        "require careful analysis of data transfer mechanisms, local data residency requirements, and country-specific regulations.",
                      )
                    }</span
                  >
                </li>
              </ul>
            </div>

            <!-- Factor 5: Data Sensitivity -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {
                  __(
                    "5. Data Sensitivity (Personal, Health, Financial, Payment Data)",
                  )
                }
              </h3>
              <p class="mb-3">
                {
                  __(
                    "The types of data you collect, process, and store directly determine your framework requirements.",
                  )
                }
              </p>
              <ul class="ml-0 list-none space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Personal data")}</strong
                    >
                    {
                      __(
                        "(names, emails, addresses): GDPR, CCPA, and general privacy frameworks",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Protected health information (PHI)")}</strong
                    >{__(": HIPAA compliance required")}</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Payment card data")}</strong
                    >{__(": PCI DSS compliance required")}</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Financial data")}</strong
                    >{
                      __(
                        ": Various financial regulations depending on data type",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Children's data")}</strong
                    >{__(": COPPA compliance required")}</span
                  >
                </li>
              </ul>
              <p class="mt-3">
                {
                  __(
                    "Many companies underestimate their data sensitivity. If your SaaS product integrates with a customer's HR system, you might be processing health insurance information—making HIPAA relevant even though you're not a \"healthcare company.\"",
                  )
                }
              </p>
            </div>

            <!-- Factor 6: Business Model -->
            <div>
              <h3 class="text-foreground mb-2 text-lg font-semibold">
                {__("6. Business Model and Revenue Streams")}
              </h3>
              <p class="mb-3">
                {
                  __(
                    "How you make money affects your compliance profile in subtle but important ways.",
                  )
                }
              </p>
              <ul class="ml-0 list-none space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Subscription SaaS models")}</strong
                    >
                    {
                      __(
                        "with recurring revenue typically face standard B2B compliance requirements centered on SOC 2 and data protection.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Advertising-supported models")}</strong
                    >
                    {
                      __(
                        "that monetize user data face heightened privacy scrutiny and may need to demonstrate compliance with consent requirements under GDPR and similar regulations.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("Marketplace models")}</strong
                    >
                    {
                      __(
                        "where you facilitate transactions between parties may have PCI DSS obligations depending on your role in payment processing.",
                      )
                    }</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span
                    ><strong class="text-foreground"
                      >{__("API-first businesses")}</strong
                    >
                    {
                      __(
                        "that other companies build upon often face elevated security requirements, as your security posture directly affects your customers' compliance status.",
                      )
                    }</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- When You Need SOC 2 -->
        <section id="soc2" class="mb-12 scroll-mt-24">
          <h2
            class="text-foreground mb-6 text-2xl font-semibold tracking-[-0.01em] sm:text-[1.75rem]"
          >
            {__("When You Need SOC 2 (B2B SaaS Selling to Enterprise)")}
          </h2>
          <div class="text-muted-foreground space-y-4 leading-relaxed">
            <p>
              <a href="/hub/soc2" class="text-[#5d770d] hover:underline"
                >{__("SOC 2")}</a
              >
              {
                __(
                  "is the de facto standard for B2B software companies selling to other businesses. You likely need SOC 2 if:",
                )
              }
            </p>
            <ul class="ml-0 list-none space-y-2">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span
                  >{
                    __("You sell software or services to other businesses")
                  }</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span
                  >{
                    __("Your customers are mid-market or enterprise companies")
                  }</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("You handle, process, or store customer data")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span
                  >{
                    __(
                      "You're receiving security questionnaires from prospects",
                    )
                  }</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Enterprise deals are stalling in procurement")}</span
                >
              </li>
            </ul>
            <p>
              {
                __(
                  "SOC 2 comes in two types. Type I is a point-in-time assessment that can be completed in weeks. Type II covers a review period (typically 3-12 months) and carries more weight with enterprise buyers.",
                )
              }
            </p>
            <p class="rounded-lg border border-[#d7edba] bg-[#f0f7e4] p-4">
              <strong class="text-foreground">{__("Priority level:")}</strong>
              {
                __(
                  "If enterprise B2B sales are your primary growth channel, SOC 2 should likely be your first compliance investment. Most enterprise procurement teams won't proceed without it.",
                )
              }
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- When You Need GDPR -->
        <section id="gdpr" class="mb-12 scroll-mt-24">
          <h2
            class="text-foreground mb-6 text-2xl font-semibold tracking-[-0.01em] sm:text-[1.75rem]"
          >
            {
              __(
                "When You Need GDPR (Serving EU Customers or Handling EU Data)",
              )
            }
          </h2>
          <div class="text-muted-foreground space-y-4 leading-relaxed">
            <p>
              {__("GDPR applies to your business if you:")}
            </p>
            <ul class="ml-0 list-none space-y-2">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Have customers located in the European Union")}</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Have employees in the European Union")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Process personal data of EU residents")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span
                  >{
                    __(
                      "Offer goods or services to people in the EU (even for free)",
                    )
                  }</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Monitor the behavior of people in the EU")}</span>
              </li>
            </ul>
            <p>
              {
                __(
                  "Importantly, GDPR applies based on whose data you process, not where your company is located. A San Francisco startup with EU customers must comply with GDPR.",
                )
              }
            </p>
            <p>
              {
                __(
                  "GDPR compliance involves implementing specific data protection practices, documenting your processing activities, potentially appointing a Data Protection Officer, and being prepared to respond to data subject requests.",
                )
              }
            </p>
            <p class="rounded-lg border border-[#d7edba] bg-[#f0f7e4] p-4">
              <strong class="text-foreground">{__("Priority level:")}</strong>
              {
                __(
                  "If you have meaningful EU revenue or plan to expand into European markets, GDPR compliance should be a near-term priority. Fines for non-compliance can reach €20 million or 4% of global revenue.",
                )
              }
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- When You Need HIPAA -->
        <section id="hipaa" class="mb-12 scroll-mt-24">
          <h2
            class="text-foreground mb-6 text-2xl font-semibold tracking-[-0.01em] sm:text-[1.75rem]"
          >
            {__("When You Need HIPAA (Healthcare Data and PHI)")}
          </h2>
          <div class="text-muted-foreground space-y-4 leading-relaxed">
            <p>
              {
                __(
