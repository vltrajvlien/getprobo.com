---
import Layout from "../layouts/Layout.astro";
import { getTranslator } from "../lib/i18n.ts";
const __ = await getTranslator(Astro.currentLocale);
---

<Layout
  title={"Page not found"}
  description={"The requested page cannot be found"}
  noFrameworks
>
  <animated-hero class="block overflow-hidden py-40">
    <h1
      class="text-h2 sm:text-h1 mb-6 overflow-hidden text-center font-medium text-balance sm:mb-8"
    >
      Page not found
    </h1>
    <p
      class="text-muted-foreground animate-perspective-in animation-delay-150 mx-auto mb-10 max-w-200 text-center text-lg text-balance"
    >
      The page you requested does not exist.
    </p>
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/"
        class="text-primary underline underline-offset-4 hover:opacity-80"
        >Homepage</a
      >
      <a
        href="/docs"
        class="text-primary underline underline-offset-4 hover:opacity-80"
        >Documentation</a
      >
      <a
        href="/blog"
        class="text-primary underline underline-offset-4 hover:opacity-80"
        >Blog</a
      >
      <a
        href="/contact"
        class="text-primary underline underline-offset-4 hover:opacity-80"
        >Contact</a
      >
    </div>
  </animated-hero>
</Layout>

<script>
  import { AnimatedHero } from "../lib/elements/hero";
  import { customElementDefine } from "../lib/dom";

  customElementDefine("animated-hero", () => AnimatedHero);
</script>
