---
import Layout from "../layouts/Layout.astro";
import FrameworkBadge from "../components/FrameworkBadge.svelte";
import { getTranslator } from "../lib/i18n.ts";
const __ = await getTranslator(Astro.currentLocale);

const frameworks = [
  {
    id: "soc2",
    label: "SOC 2",
    title: "What is SOC 2",
    description:
      "This guide breaks down SOC 2 in simple terms: what it is, why it matters, who needs it, and how to prepare without overcomplicating things.",
    features: ["Understanding SOC 2", "Why it is needed", "What solutions exists"],
    href: "/compliance-guides/soc2",
    colorFrom: "#1a3a2e",
    colorTo: "#2d5a4a",
    badges: ["SOC2_TYPE1", "SOC2_TYPE2"],
  },
];
---

<Layout
  title={__("Compliance Guides")}
  description={__("Everything you need to understand about compliance frameworks.")}
>
  <main class="container my-10 sm:my-20">
    <!-- Hero Section -->
    <div class="text-center mb-10 sm:mb-16">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[rgba(147,201,38,0.12)] bg-white/60 backdrop-blur-[50px] text-xs text-muted-foreground mb-6 animate-slide-in"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
          ></path>
        </svg>
        {__("Compliance Knowledge Center")}
      </div>
      <h1
        class="text-h2 sm:text-h1 mb-6 font-medium animate-slide-in animation-delay-100"
      >
        {__("Your Complete Compliance Guides")}
      </h1>
      <p
        class="text-muted-foreground text-lg sm:text-xl font-medium max-w-[600px] mx-auto animate-slide-in animation-delay-200"
      >
        {__("Everything you need to know about compliance frameworks. From basics to certification.")}
      </p>
    </div>

    <!-- Frameworks Section -->
    <section class="animate-slide-in animation-delay-300">
      <div class="mb-10">
        <h2 class="text-h3 sm:text-[40px] sm:leading-[54px] font-medium mb-3 tracking-[-0.8px]">
          {__("Available Frameworks")}
        </h2>
        <p class="text-muted-foreground text-lg">
          {__("Start your compliance journey with our comprehensive guides")}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8">
        {
          frameworks.map((framework) => (
            <article
              class="group relative overflow-hidden rounded-3xl min-h-[420px] sm:min-h-[480px] transition-transform hover:scale-[1.02]"
              style={`background: linear-gradient(135deg, ${framework.colorFrom} 0%, ${framework.colorTo} 100%)`}
            >
              <div class="relative h-full flex flex-col justify-between p-6 sm:p-8">
                <!-- Content -->
                <div class="flex flex-col gap-6">
                  <div class="flex flex-col gap-4">
                    <h3 class="text-[28px] sm:text-[36px] leading-[1.15] sm:leading-[42px] font-medium text-[#fcfdfc] tracking-[-0.8px]">
                      {framework.title}
                    </h3>
                    <p class="text-[#e4f7c7] text-base leading-[26px]">
                      {framework.description}
                    </p>
                  </div>

                  <!-- Features -->
                  <ul class="flex flex-col gap-3">
                    {framework.features.map((feature) => (
                      <li class="flex items-center gap-2.5">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="18"
                          height="18"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="#e4f7c7"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="shrink-0"
                        >
                          <circle cx="12" cy="12" r="10" />
                          <path d="m9 12 2 2 4-4" />
                        </svg>
                        <span class="text-[#fcfdfc] text-sm leading-[22px]">
                          {feature}
                        </span>
                      </li>
                    ))}
                  </ul>

                  <!-- Button -->
                  <div class="flex items-center justify-between mt-2">
                    <a
                      href={framework.href}
                      class="relative inline-flex items-center gap-2 h-[44px] px-6 bg-[#ffffff] rounded-full text-[15px] font-medium text-[#141e12] tracking-[-0.1px] transition-shadow hover:shadow-[0px_4px_12px_0px_rgba(11,19,36,0.15)]"
                    >
                      {__("Access Complete Guide")}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                      </svg>
                    </a>
                    <!-- Framework Badges -->
                    <div class="flex items-center gap-1 bg-white rounded-2xl p-3">
                      {framework.badges.map((badge) => (
                        <FrameworkBadge name={badge} class="size-20" client:visible />
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Coming Soon Section -->
    <section class="mt-10 sm:mt-16 animate-slide-in animation-delay-400">
      <div
        class="bg-gradient-to-br from-[#e4f7c7] to-[#d0e8b3] rounded-3xl p-8 sm:p-12"
      >
        <div class="flex flex-col gap-6 items-center text-center">
          <div
            class="bg-[#141e12] rounded-2xl size-16 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#e4f7c7"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
              ></path>
            </svg>
          </div>
          <div class="flex flex-col gap-3">
            <h3
              class="text-h4 sm:text-[32px] sm:leading-[42px] font-medium text-[#141e12] tracking-[-0.8px]"
            >
              {__("More guides coming soon")}
            </h3>
            <p class="text-muted-foreground text-lg max-w-[600px]">
              {
                __(
                  "We're constantly expanding our compliance knowledge center. Stay tuned for guides on GDPR, HIPAA, and more frameworks."
                )
              }
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
