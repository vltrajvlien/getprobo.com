---
import Layout from "../layouts/Layout.astro";
import PricingCards from "../components/block/PricingCards.astro";
import Testimonials from "../components/block/Testimonials.astro";
import { getTranslator } from "../lib/i18n.ts";

const __ = await getTranslator(Astro.currentLocale);

const whatsIncluded = [
  {
    title: __("Gap Assessment & Risk Analysis"),
    description: __("We run a full risk assessment, identify the gaps, and build your action plan — ready for your review."),
    icon: "search",
  },
  {
    title: __("Custom Policies & Documentation"),
    description: __("Security policies written for your company — adapted to your stack, your processes, and your constraints."),
    icon: "file",
  },
  {
    title: __("Vendor Security Reviews"),
    description: __("We review your third-party vendors and handle the security questionnaires. You approve the results."),
    icon: "shield",
  },
  {
    title: __("Employee Training"),
    description: __("We coordinate security awareness training for your team — you just show up."),
    icon: "graduation",
  },
  {
    title: __("Audit Prep & Representation"),
    description: __("We collect evidence, prep the materials, join the auditor calls, and handle findings."),
    icon: "clipboard",
  },
  {
    title: __("12-Month Maintenance"),
    description: __("Quarterly reviews, continuous monitoring, security questionnaires handled. We don't disappear after the audit."),
    icon: "refresh",
  },
];

const howItWorks = [
  {
    step: "01",
    title: __("Onboarding Call"),
    description: __("A 30-minute call to understand your stack, your team, and your compliance goals."),
  },
  {
    step: "02",
    title: __("Build Your Program"),
    description: __("We run a full risk assessment and build a compliance program adapted to your company — policies, vendor reviews, controls. Your only job: implement the security measures we identify."),
  },
  {
    step: "03",
    title: __("Collect Evidence"),
    description: __("Our platform automates evidence collection. We verify everything is in order before moving to audit."),
  },
  {
    step: "04",
    title: __("Audit & Certification"),
    description: __("We coordinate the auditor, join every call, and manage any findings. You'll talk to the auditor (it's your company) — but we'll be right there with you."),
  },
  {
    step: "05",
    title: __("Run Compliance"),
    description: __("Monthly or quarterly security reviews, continuous monitoring, security questionnaires handled. We maintain your compliance so you never fall behind."),
  },
];

const faqItems = [
  {
    question: __("How is Probo different from compliance tools?"),
    answer: __("Most tools give you a dashboard and leave you to figure it out. We do the actual work — gap assessments, policy writing, vendor reviews, audit prep. You get a dedicated compliance officer, not a login."),
  },
  {
    question: __("What do I actually have to do?"),
    answer: __("Implement the security measures we identify. That's it. We handle everything else — risk analysis, documentation, vendor reviews, training coordination, audit prep, and ongoing monitoring."),
  },
  {
    question: __("How long does it take to get certified?"),
    answer: __("Most companies are audit-ready in 6 to 8 weeks. The exact timeline depends on your current security posture and the framework you're pursuing."),
  },
  {
    question: __("Do I need to learn SOC 2 or ISO 27001?"),
    answer: __("No. That's the whole point. We translate compliance requirements into clear, actionable tasks for your team. No jargon, no guesswork."),
  },
  {
    question: __("We already have some security measures in place. Can Probo work with that?"),
    answer: __("Absolutely. We start with a gap assessment to see what you already have, then build on it. We don't start from scratch if you don't need to."),
  },
  {
    question: __("What happens after we get certified?"),
    answer: __("We stay. 12 months of maintenance are included — quarterly reviews, continuous monitoring, security questionnaires, renewal prep. We don't disappear after the audit."),
  },
  {
    question: __("What's the Probo platform? Do I have to use it?"),
    answer: __("Probo is our open-source compliance platform. It automates evidence collection and keeps your compliance program up to date. Full Service clients use it as part of the service — we set it up and manage it for you."),
  },
  {
    question: __("Do you handle ISO 27001 and other frameworks too?"),
    answer: __("Yes. We handle SOC 2, ISO 27001, GDPR, HIPAA, and more. If you don't see your framework, reach out — we likely cover it."),
  },
];
---

<Layout
  title={__("Pricing")}
  description={__("Get audit-ready. We handle everything from gap assessment to audit day. Pick the plan that fits, or deploy our open-source platform.")}
>
  <!-- Pricing Section — Hero + Plans -->
  <PricingCards />

  <!-- What's Included -->
  <section class="py-16 sm:py-24 px-6 border-t border-border-low">
    <div class="container">
      <div class="text-center">
        <h2 class="text-h3 sm:text-h2 font-medium animate-slide-in">
          {__("Everything you need to get certified")}
        </h2>
        <p class="mt-3 text-muted-foreground animate-slide-in animation-delay-100">
          {__("Every policy, every review, every audit call — handled by compliance experts who know your stack.")}
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 animate-slide-in animation-delay-200">
        {whatsIncluded.map((card) => (
          <div class="rounded-2xl border border-border-mid shadow-mid p-6">
            <div class="mb-2">
              {card.icon === "search" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              )}
              {card.icon === "file" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
              )}
              {card.icon === "shield" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 12 11 14 15 10"></polyline>
                </svg>
              )}
              {card.icon === "graduation" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                </svg>
              )}
              {card.icon === "clipboard" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                  <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                  <path d="M12 11h4"></path>
                  <path d="M12 16h4"></path>
                  <path d="M8 11h.01"></path>
                  <path d="M8 16h.01"></path>
                </svg>
              )}
              {card.icon === "refresh" && (
                <svg class="h-6 w-6 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M23 4v6h-6"></path>
                  <path d="M1 20v-6h6"></path>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              )}
            </div>
            <h3 class="mt-2 text-base font-semibold">{card.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 sm:py-24 px-6 border-t border-border-low">
    <div class="container max-w-3xl">
      <div class="text-center">
        <h2 class="text-h3 sm:text-h2 font-medium animate-slide-in">
          {__("How we get you audit-ready")}
        </h2>
        <p class="mt-3 text-muted-foreground animate-slide-in animation-delay-100">
          {__("You focus on your product. We get you audit-ready.")}
        </p>
      </div>

      <div class="mt-14 space-y-10 animate-slide-in animation-delay-200">
        {howItWorks.map((item) => (
          <div class="flex gap-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">
              {item.step}
            </div>
            <div>
              <h3 class="font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                {item.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ -->
  <section class="py-16 sm:py-24 px-6">
    <div class="container max-w-3xl">
      <h2 class="text-center text-h3 sm:text-h2 font-medium animate-slide-in">
        {__("Frequently asked questions")}
      </h2>

      <div class="mt-10 divide-y divide-border-low animate-slide-in animation-delay-100">
        {faqItems.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between text-left text-sm font-medium list-none [&::-webkit-details-marker]:hidden">
              <span>{item.question}</span>
              <svg
                class="size-4 shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <p class="pt-3 text-sm text-muted-foreground leading-relaxed">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
