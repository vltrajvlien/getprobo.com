            <span class="text-muted-foreground text-sm"
              >{__("You fill out templates (if you find the right ones)")}</span
            >
          </div>
        </div>
      </div>

      <!-- Row 4: Audit Management -->
      <div
        class="border-border-low grid grid-cols-[1.2fr_1fr_1fr] border-b transition-colors hover:bg-[#fafafa] sm:grid-cols-[1.5fr_1fr_1fr]"
      >
        <div
          class="border-border-low flex items-center gap-3 border-r p-4 sm:p-5"
        >
          <div
            class="bg-accent/10 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="text-accent"
            >
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <span class="text-sm font-medium">{__("Audit Management")}</span>
        </div>
        <div class="border-border-low border-r p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
