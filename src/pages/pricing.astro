              ></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
          <span class="text-sm font-medium">{__("Documentation")}</span>
        </div>
        <div class="border-border-low border-r p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              class="text-accent mt-0.5 flex-shrink-0"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-foreground text-sm"
              >{
                __("We write all policies, procedures, and manage evidence")
              }</span
            >
          </div>
        </div>
        <div class="p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
