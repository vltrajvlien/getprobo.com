---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.svelte";
import { getTranslator, getLink } from "../lib/i18n.ts";

const __ = await getTranslator(Astro.currentLocale);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Probo Full-Service Compliance",
  description:
    "End-to-end compliance management service for SOC 2, ISO 27001, GDPR, and HIPAA.",
  provider: {
    "@type": "Organization",
    name: "Probo",
    url: "https://www.getprobo.com",
  },
  serviceType: "Compliance Management",
  areaServed: {
    "@type": "Place",
    name: "Worldwide",
  },
  offers: {
    "@type": "Offer",
    price: "8000",
    priceCurrency: "USD",
    priceSpecification: {
      "@type": "UnitPriceSpecification",
      price: "8000",
      priceCurrency: "USD",
      unitText: "year",
    },
    url: "https://www.getprobo.com/pricing",
  },
};
---

<Layout
  title={__("Pricing")}
  description={__(
    "We Handle Your Compliance. Probo isn't another compliance dashboard. We're your dedicated compliance team. Starting at $8,000 per year.",
  )}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <!-- Hero Section -->
  <animated-hero class="relative block overflow-hidden py-16 sm:py-24">
    <div class="container text-center">
      <!-- Badge -->
      <div
        class="border-border-mid animate-slide-in mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-2"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-muted-foreground"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <span class="text-muted-foreground text-sm"
          >{__("Full-Service Compliance | Not Just Software")}</span
        >
      </div>

      <!-- Main Heading -->
      <h1
        class="text-h2 sm:text-h1 animate-slide-in animation-delay-100 mb-6 font-medium"
      >
        {__("We Handle Your")}<br />
        {__("Compliance.")}
      </h1>

      <!-- Subtitle -->
      <p
        class="text-muted-foreground animate-slide-in animation-delay-150 mx-auto mb-16 max-w-[500px] text-lg"
      >
        {__("Probo isn't another compliance dashboard.")}<br />
        {__("We're your dedicated compliance team.")}
      </p>

      <!-- 3 Step Cards -->
      <div
        class="animate-slide-in animation-delay-200 mx-auto grid max-w-[900px] gap-6 sm:grid-cols-3"
      >
        <!-- Step 1 -->
        <div
          class="border-border-mid shadow-mid rounded-2xl border bg-white p-6 text-center"
        >
          <div
            class="border-border-mid mb-5 inline-flex items-center gap-3 rounded-full border px-4 py-2"
          >
            <span class="text-accent text-lg font-semibold">01</span>
            <span class="font-medium">{__("Talk to Us")}</span>
          </div>
          <p class="text-muted-foreground text-sm">
            {__("Share your tech stack and process in an onboarding call")}
          </p>
        </div>

        <!-- Step 2 -->
        <div
          class="border-border-mid shadow-mid rounded-2xl border bg-white p-6 text-center"
        >
          <div
            class="border-border-mid mb-5 inline-flex items-center gap-3 rounded-full border px-4 py-2"
          >
            <span class="text-accent text-lg font-semibold">02</span>
            <span class="font-medium">{__("We Do the Work")}</span>
          </div>
          <p class="text-muted-foreground text-sm">
            {
              __(
                "Our experts handle assessments, docs, and prepare you for audit",
              )
            }
          </p>
        </div>

        <!-- Step 3 -->
        <div
          class="border-border-mid shadow-mid rounded-2xl border bg-white p-6 text-center"
        >
          <div
            class="border-border-mid mb-5 inline-flex items-center gap-3 rounded-full border px-4 py-2"
          >
            <span class="text-accent text-lg font-semibold">03</span>
            <span class="font-medium">{__("You Get Certified")}</span>
          </div>
          <p class="text-muted-foreground text-sm">
            {
              __(
                "Achieve SOC 2, ISO 27001, or other frameworks with serious audit",
              )
            }
          </p>
        </div>
      </div>
    </div>
  </animated-hero>

  <!-- Probo Service Pricing Section -->
  <section class="border-border-mid border-y bg-[#F8F9F8] py-16 sm:py-24">
    <div class="container">
      <div class="mb-12 text-center">
        <h2 class="text-h3 sm:text-h2 mb-4 font-medium">
          {__("Probo Service Pricing")}
        </h2>
        <p class="text-muted-foreground mx-auto max-w-[600px]">
          {
            __(
              "Final price depends on your company size, the framework you're pursuing (SOC 2, ISO 27001, etc.), and your current security posture.",
            )
          }
        </p>
      </div>

      <!-- Pricing Card -->
      <div class="mx-auto max-w-[420px]">
        <!-- Full-Service Badge -->
        <div class="relative z-10 mb-[-20px] flex justify-center">
          <span
            class="rounded-full bg-[#93C925] px-6 py-2.5 text-base font-semibold text-[#2A2A3D]"
          >
            {__("Full-Service Compliance")}
          </span>
        </div>

        <!-- Dark Card -->
        <div
          class="rounded-2xl border-4 border-[#E4F7C7] bg-[#2A2A3D] p-6 pt-10 shadow-[0_8px_30px_rgba(0,0,0,0.2)] sm:p-8 sm:pt-12"
        >
          <!-- Price -->
          <div class="mb-1">
            <span class="text-base font-medium text-[#ffffff]"
              >{__("Starting at")}</span
            >
          </div>
          <div class="mb-2 flex items-baseline gap-2">
            <span class="text-[2.5rem] font-bold text-[#ffffff] sm:text-[3rem]"
              >$8,000</span
            >
            <span class="text-sm text-[#ffffffb3]">{__("per year")}</span>
          </div>
          <p class="mb-5 text-sm text-[#ffffffb3]">
            {__("End-to-end compliance, fully managed for you")}
          </p>

          <!-- Price For Box -->
          <div class="mb-6 rounded-lg bg-[#3a3a50] px-4 py-3">
            <span
              class="text-accent text-xs font-medium tracking-wide uppercase"
              >{__("PRICE FOR")}</span
            >
            <p class="mt-0.5 text-sm text-[#ffffff]">
              {__("a small team (0-15 employees)")}
            </p>
          </div>

          <!-- Features List -->
          <ul class="mb-6 space-y-2.5">
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm font-medium text-[#ffffff]"
                >{__("One compliance framework (ISO 27001, SOC 2,...)")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Gap assessment & risk analysis")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("All policy & documentation writing")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Full vendor review management")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Audit prep & management")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Security questionnaire")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Contract redlining")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Dedicated Compliance officer on Slack & Meet")}</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="text-accent mt-0.5 flex-shrink-0"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="text-sm text-[#ffffffcc]"
                >{__("Continuous monitoring & updates*")}</span
              >
            </li>
          </ul>

          <!-- CTA Button -->
          <a
            href={getLink(Astro, "/contact")}
            class="bg-accent text-foreground hover:bg-accent/90 block w-full rounded-lg py-4 text-center font-medium transition-colors"
          >
            {__("Get your price")} →
          </a>
        </div>
      </div>

      <!-- Continuous Monitoring Note -->
      <div class="mx-auto mt-12 max-w-[900px]">
        <div
          class="border-border-mid rounded-2xl border bg-white p-6 text-center sm:p-8"
        >
          <h3 class="mb-2 text-lg font-medium">
            {__("*Continuous monitoring over the year")}
          </h3>
          <p class="text-muted-foreground mx-auto max-w-[700px]">
            {
              __(
                "Once certified, we run your compliance program in the background - monitoring, updating controls, refreshing evidence, and maintaining assessments.",
              )
            }
            {" "}<span class="text-accent font-medium"
              >{__("So you remain continuously audit-ready")}</span
            >{" "}
            {__("with no extra effort.")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service, Not Software Section -->
  <section class="container py-16 sm:py-24">
    <div class="mb-12 text-center">
      <h2 class="text-h3 sm:text-h2 mb-4 font-medium">
        {__("Service, Not Software")}
      </h2>
      <p class="text-muted-foreground mx-auto max-w-[550px]">
        {
          __(
            "Most platforms give you a tool and leave you to figure it out. We do the actual work for you.",
          )
        }
      </p>
    </div>

    <!-- Comparison Table -->
    <div
      class="border-border-mid shadow-mid mx-auto max-w-[1000px] overflow-hidden rounded-2xl border bg-white"
    >
      <!-- Table Header -->
      <div
        class="grid grid-cols-[1.2fr_1fr_1fr] bg-[#2A2A3D] sm:grid-cols-[1.5fr_1fr_1fr]"
      >
        <div class="flex items-center p-4 sm:p-5">
          <span class="text-sm font-medium text-[#ffffff99]"
            >{__("Category")}</span
          >
        </div>
        <div class="flex items-center justify-center p-4 sm:p-5">
          <span
            class="bg-accent inline-block rounded-full px-5 py-2 text-sm font-semibold text-[#2A2A3D]"
          >
            {__("Probo (Full Service)")}
          </span>
        </div>
        <div class="flex items-center justify-center p-4 sm:p-5">
          <span class="text-sm font-medium text-[#ffffff99]"
            >{__("Typical Platforms (Tool)")}</span
          >
        </div>
      </div>

      <!-- Table Rows -->
      <!-- Row 1: Time Investment -->
      <div
        class="border-border-low grid grid-cols-[1.2fr_1fr_1fr] border-b transition-colors hover:bg-[#fafafa] sm:grid-cols-[1.5fr_1fr_1fr]"
      >
        <div
          class="border-border-low flex items-center gap-3 border-r p-4 sm:p-5"
        >
          <div
            class="bg-accent/10 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="text-accent"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <span class="text-sm font-medium">{__("Time Investment")}</span>
        </div>
        <div class="border-border-low border-r p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              class="text-accent mt-0.5 flex-shrink-0"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-foreground text-sm"
              >{
                __(
                  "~2 hours per month (just implement what we tell you - that part can take you time)",
                )
              }</span
            >
          </div>
        </div>
        <div class="p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-quaternary mt-0.5 flex-shrink-0"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
            <span class="text-muted-foreground text-sm"
              >{
                __(
                  "Many hours managing frameworks yourself (not focusing on your business)",
                )
              }</span
            >
          </div>
        </div>
      </div>

      <!-- Row 2: Risk and Vendors Assessments -->
      <div
        class="border-border-low grid grid-cols-[1.2fr_1fr_1fr] border-b transition-colors hover:bg-[#fafafa] sm:grid-cols-[1.5fr_1fr_1fr]"
      >
        <div
          class="border-border-low flex items-center gap-3 border-r p-4 sm:p-5"
        >
          <div
            class="bg-accent/10 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="text-accent"
            >
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <span class="text-sm font-medium"
            >{__("Risk and Vendors Assessments")}</span
          >
        </div>
        <div class="border-border-low border-r p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              class="text-accent mt-0.5 flex-shrink-0"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="text-foreground text-sm"
              >{
                __(
                  "We perform a proper risk analysis for your company and each of your vendors",
                )
              }</span
            >
          </div>
        </div>
        <div class="p-4 sm:p-5">
          <div class="flex items-start gap-2">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-quaternary mt-0.5 flex-shrink-0"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
            <span class="text-muted-foreground text-sm"
              >{
                __(
                  "You follow tutorials and hope it's correct (often reduced to box-ticking)",
                )
              }</span
            >
          </div>
        </div>
      </div>

      <!-- Row 3: Documentation -->
      <div
        class="border-border-low grid grid-cols-[1.2fr_1fr_1fr] border-b transition-colors hover:bg-[#fafafa] sm:grid-cols-[1.5fr_1fr_1fr]"
      >
        <div
          class="border-border-low flex items-center gap-3 border-r p-4 sm:p-5"
        >
          <div
            class="bg-accent/10 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-xl"
