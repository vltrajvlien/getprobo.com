---
import Layout from "../../layouts/Layout.astro";
import FrameworkBadge from "../../components/FrameworkBadge.svelte";
import { getTranslator } from "../../lib/i18n.ts";
const __ = await getTranslator(Astro.currentLocale);

const tableOfContents = [
  { id: "what-is-soc2", label: "What is SOC 2?" },
  { id: "is-soc2-certification", label: "Is SOC 2 a certification?" },
  { id: "what-does-soc2-evaluate", label: "What does SOC 2 evaluate?" },
  { id: "type1-vs-type2", label: "What is the difference between SOC 2 Type I and Type II?" },
  { id: "how-long", label: "How long does it take to become SOC 2 compliant?" },
  { id: "estimate-timeline", label: "How can I estimate the SOC 2 timeline for my company?" },
  { id: "phases", label: "What are the phases of a SOC 2 project?" },
  { id: "cost", label: "How much does SOC 2 cost?" },
  { id: "hidden-costs", label: "What are the hidden costs of SOC 2?" },
  { id: "pentest", label: "Is penetration testing required for SOC 2?" },
  { id: "too-early", label: "When is it too early to do SOC 2?" },
  { id: "faster", label: "How can we get SOC 2 faster?" },
  { id: "soc2-vs-iso", label: "What is the difference between SOC 2 and ISO 27001?" },
  { id: "choose", label: "Should we choose SOC 2 or ISO 27001?" },
  { id: "close-deals", label: "Can SOC 2 help close deals?" },
  { id: "probo-help", label: "How does Probo help with SOC 2?" },
];
---

<Layout
  title={__("A Practical and Complete Guide to SOC 2 Compliance")}
  description={__("A comprehensive guide to understand SOC 2 for beginners. Learn what SOC 2 is, why it matters, and how to prepare.")}
>
  <main class="container my-10 sm:my-20">
    <!-- Header -->
    <header class="mb-12 sm:mb-16">
      <div class="flex items-center gap-4 mb-4">
        <h1 class="text-[2.5rem] sm:text-[3.5rem] leading-[1.1] font-semibold tracking-[-0.02em] text-foreground">
          {__("A Practical and Complete Guide to SOC 2 Compliance")}
        </h1>
        <div class="flex items-center gap-2">
          <FrameworkBadge name="SOC2_TYPE1" class="size-12" client:visible />
          <FrameworkBadge name="SOC2_TYPE2" class="size-12" client:visible />
        </div>
      </div>
      <p class="text-muted-foreground text-lg">
        {__("FAQ to understand SOC 2 for beginners")}
      </p>
    </header>

    <!-- Content with TOC -->
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">
      <!-- Table of Contents - Sidebar -->
      <aside class="lg:w-56 shrink-0">
        <nav class="lg:sticky lg:top-24">
          <div class="flex flex-col gap-2">
            {tableOfContents.map((item) => (
              <button
                type="button"
                data-section={item.id}
                class="toc-link text-sm text-[#6b716a] hover:text-[#141e12] transition-colors text-left bg-transparent border-none p-0 cursor-pointer leading-5"
              >
                {item.label}
              </button>
            ))}
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <article class="flex-1 max-w-[720px]">
        <!-- What is SOC 2? -->
        <section id="what-is-soc2" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What is SOC 2?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("SOC 2 is an independent audit report that evaluates how a company protects customer data. It is issued by a licensed third-party auditor under a framework developed by the")} <a href="https://www.aicpa-cima.com/home" target="_blank" rel="noopener noreferrer" class="text-[#5d770d] hover:underline">{__("AICPA (American Institute of Certified Public Accountants)")}</a>.
            </p>
            <p>
                {__("It is delivered as a detailed report that enterprise customers review to assess whether they can trust your company with sensitive data.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- Is SOC 2 a certification? -->
        <section id="is-soc2-certification" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("Is SOC 2 a certification?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("No. SOC 2 is not a certification. It is an attestation report expressing an auditor's opinion on whether your security controls are properly designed and operating effectively.")}
            </p>
            <p>
              {__("There is no \"pass\" or \"fail.\" What matters is:")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("The scope of systems included")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("The Trust Services Criteria covered")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("The auditor's findings and exceptions")}</span>
              </li>
            </ul>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- What does SOC 2 evaluate? -->
        <section id="what-does-soc2-evaluate" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What does SOC 2 evaluate?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("SOC 2 evaluates your controls against the Trust Services Criteria (TSC):")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Security")}</strong> {__("(mandatory): Protection against unauthorized access")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Availability")}</strong>{__(": Systems are available and operational as agreed")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Processing Integrity")}</strong>{__(": Data is processed accurately and completely")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Confidentiality")}</strong>{__(": Confidential information is protected")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Privacy")}</strong>{__(": Personal data is collected, used, and disclosed properly")}</span>
              </li>
            </ul>
            <p>
              {__("Every SOC 2 report must include Security. The other criteria are optional and should be chosen based on customer expectations and business needs.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- What is the difference between SOC 2 Type I and Type II? -->
        <section id="type1-vs-type2" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What is the difference between SOC 2 Type I and Type II?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("SOC 2 Type I is a point-in-time assessment. It confirms that your controls are properly designed at a specific date.")}
            </p>
            <p>
              {__("SOC 2 Type II evaluates how those controls operate over time, typically over 3 to 12 months.")}
            </p>
            <p class="flex items-start gap-2">
              <span>👉</span>
              <span>{__("Most enterprise customers expect a SOC 2 Type II, as it demonstrates real operational maturity.")}</span>
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- How long does it take to get SOC 2 compliant? -->
        <section id="how-long" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("How long does it take to become SOC 2 compliant?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("There is no single answer, but for most small companies:")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("SOC 2 Type I")}</strong>{__(": ~1 to 2 months")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("SOC 2 Type II")}</strong>{__(": 3 to 12 months (including the observation period)")}</span>
              </li>
            </ul>
            <p>
              {__("The timeline depends mainly on:")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Company size (process change is harder as teams grow)")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Technical stack complexity")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Existing security maturity")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Internal time availability")}</span>
              </li>
            </ul>
            <p>
              {__("For companies with a simple stack, the actual technical work can take less than 10 hours. Most of the time is spent on documentation, evidence collection, and audit coordination.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- How can I estimate the SOC 2 timeline for my company? -->
        <section id="estimate-timeline" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("How can I estimate the SOC 2 timeline for my company?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("You can estimate your SOC 2 timeline by answering three questions:")}
            </p>
            <ol class="list-none space-y-4 ml-0">
              <li>
                <p class="text-foreground font-medium">{__("Have customers or prospects asked for SOC 2?")}</p>
                <p class="text-sm">{__("If yes, you likely need it now.")}</p>
              </li>
              <li>
                <p class="text-foreground font-medium">{__("Is your infrastructure relatively stable?")}</p>
                <p class="text-sm">{__("Frequent changes slow audits dramatically.")}</p>
              </li>
              <li>
                <p class="text-foreground font-medium">{__("Who will own compliance internally?")}</p>
                <p class="text-sm">{__("SOC 2 always requires someone accountable.")}</p>
              </li>
            </ol>
            <p>
              {__("Traditionally, readiness takes 1 to 4 months, followed by the audit and (for Type II) the observation period. With an expert-led approach like")} <a href="https://www.getprobo.com/" target="_blank" rel="noopener noreferrer" class="text-[#5d770d] hover:underline">Probo</a>{__(", the readiness phase can be drastically shortened.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- What are the phases of a SOC 2 project? -->
        <section id="phases" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What are the phases of a SOC 2 project?")}
          </h2>
          <div class="space-y-6 text-muted-foreground leading-relaxed">
            <!-- Phase 1 -->
            <div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{__("Phase 1: Readiness and remediation")}</h3>
              <p class="text-sm mb-2"><strong class="text-foreground">{__("Timeline:")}</strong> {__("~1 to 4 months")}</p>
              <p class="mb-2">{__("This is the heaviest phase:")}</p>
              <ul class="list-none space-y-1 ml-0">
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span>{__("Scope definition")}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span>{__("Gap analysis")}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span>{__("Control implementation")}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-muted-foreground">•</span>
                  <span>{__("Policies and documentation")}</span>
                </li>
              </ul>
              <p class="mt-2">{__("Even with automation tools, this phase requires real decision-making and documentation work.")}</p>
            </div>

            <!-- Phase 2 -->
            <div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{__("Phase 2: Observation period (Type II only)")}</h3>
              <p class="text-sm mb-2"><strong class="text-foreground">{__("Timeline:")}</strong> {__("3 to 12 months")}</p>
              <p>{__("You collect evidence to prove your controls operate consistently over time. Most startups choose 3 months.")}</p>
            </div>

            <!-- Phase 3 -->
            <div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{__("Phase 3: Audit")}</h3>
              <p class="text-sm mb-2"><strong class="text-foreground">{__("Timeline:")}</strong> {__("1 to 6 weeks")}</p>
              <p>{__("The auditor reviews evidence, interviews key team members, and writes the report.")}</p>
            </div>

            <!-- Phase 4 -->
            <div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{__("Phase 4: Maintenance")}</h3>
              <p class="text-sm mb-2"><strong class="text-foreground">{__("Timeline:")}</strong> {__("Ongoing (monthly effort)")}</p>
              <p>{__("SOC 2 is annual. Controls must be maintained to avoid starting from scratch each year.")}</p>
            </div>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- How much does SOC 2 cost? -->
        <section id="cost" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("How much does SOC 2 cost?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("For a small company, a realistic annual SOC 2 budget is around $10,000 if done efficiently.")}
            </p>
            <p>{__("Typical breakdown:")}</p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Audit")}</strong>{__(": $6,000–$7,000")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Implementation & tooling")}</strong>{__(": varies widely")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("Hidden cost")}</strong>{__(": internal time and distraction")}</span>
              </li>
            </ul>
            <p>
              {__("Consultants can cost $50,000+, and automation tools still require a dedicated internal owner.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- What are the hidden costs of SOC 2? -->
        <section id="hidden-costs" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What are the hidden costs of SOC 2?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("The biggest hidden cost is internal time:")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Defining scope")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Customizing policies")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Managing evidence")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Coordinating auditors")}</span>
              </li>
            </ul>
            <p>
              {__("In many startups, this turns a CTO or engineer into a part-time compliance manager for months.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- Is penetration testing required for SOC 2? -->
        <section id="pentest" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("Is penetration testing required for SOC 2?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("No. SOC 2 does not require penetration testing.")}
            </p>
            <p>
              {__("It can be useful once your product stabilizes, but it is not mandatory and often overkill for early-stage startups.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- When is it too early to do SOC 2? -->
        <section id="too-early" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("When is it too early to do SOC 2?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("It's probably too early if:")}
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("You don't handle sensitive customer data")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("No customer, partner, or investor has asked for it")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Your infrastructure changes weekly")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Your product or market is still being validated")}</span>
              </li>
            </ul>
            <p>
              {__("Doing SOC 2 too early often wastes time and money. A better approach is to focus on security fundamentals first.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- How can we get SOC 2 faster? -->
        <section id="faster" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("How can we get SOC 2 faster?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p>
              {__("Speed comes from expertise, not tools alone.")}
            </p>
            <p>
              {__("With a done-for-you service like")} <a href="https://www.getprobo.com/" target="_blank" rel="noopener noreferrer" class="text-[#5d770d] hover:underline">Probo</a>:
            </p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Scoping is done correctly from day one")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Documentation is written for your real workflows")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Engineers only implement what's necessary")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Audit coordination is fully managed")}</span>
              </li>
            </ul>
            <p>
              {__("This turns months of internal effort into a focused, low-distraction process.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- What is the difference between SOC 2 and ISO 27001? -->
        <section id="soc2-vs-iso" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("What is the difference between SOC 2 and ISO 27001?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("SOC 2")}</strong> {__("produces a detailed report focused on customer trust (common in North America)")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span><strong class="text-foreground">{__("ISO 27001")}</strong> {__("produces a certification proving you run a formal Information Security Management System (ISMS)")}</span>
              </li>
            </ul>
            <p>
              {__("They are not interchangeable. Customers usually ask for one or the other.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- Should we choose SOC 2 or ISO 27001? -->
        <section id="choose" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("Should we choose SOC 2 or ISO 27001?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
            <p class="text-foreground font-medium">{__("Choose SOC 2 if:")}</p>
            <ul class="list-none space-y-2 ml-0 mb-4">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("Your customers are mainly in North America")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("You sell B2B or enterprise software")}</span>
              </li>
            </ul>
            <p class="text-foreground font-medium">{__("Choose ISO 27001 if:")}</p>
            <ul class="list-none space-y-2 ml-0">
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("You target international or European markets")}</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-muted-foreground">•</span>
                <span>{__("You need a globally recognized certification")}</span>
              </li>
            </ul>
            <p>
              {__("Many growing startups eventually need both.")}
            </p>
          </div>
        </section>

        <hr class="border-border-low mb-12" />

        <!-- Can SOC 2 help close deals? -->
        <section id="close-deals" class="scroll-mt-24 mb-12">
          <h2 class="text-2xl sm:text-[1.75rem] font-semibold tracking-[-0.01em] text-foreground mb-6">
            {__("Can SOC 2 help close deals?")}
          </h2>
          <div class="space-y-4 text-muted-foreground leading-relaxed">
